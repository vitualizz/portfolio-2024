---
import '@fontsource-variable/bricolage-grotesque'
import '@fontsource-variable/dm-sans'
import bricolageUrl from '@fontsource-variable/bricolage-grotesque/files/bricolage-grotesque-latin-wght-normal.woff2?url'
import dmSansUrl from '@fontsource-variable/dm-sans/files/dm-sans-latin-wght-normal.woff2?url'
import '../styles/global.css'
import GlobalSpotlight from 'src/components/GlobalSpotlight.astro'
import { getLangFromUrl, useTranslation } from 'src/i18n/utils'
import { ClientRouter } from 'astro:transitions'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const tSeo = t('seo')
const { title, description, ogImage: ogImageProp } = Astro.props

const pageTitle = title ?? tSeo.title
const pageDescription = description ?? tSeo.description
const ogLocale = lang === 'es' ? 'es_ES' : 'en_US'
const canonicalUrl = new URL(Astro.url.pathname, Astro.url)
const ogImage = ogImageProp
  ? new URL(ogImageProp, Astro.url)
  : new URL('/img/seo/og-image.png', Astro.url)
const twitterImage = ogImageProp
  ? new URL(ogImageProp, Astro.url)
  : new URL('/img/seo/twitter-image.png', Astro.url)
---

<html lang={lang} data-theme="dark">
  <head>
    <script is:inline>
      function applyTheme() {
        const stored = localStorage.getItem('portfolio-theme')
        if (stored) document.documentElement.setAttribute('data-theme', stored)
      }
      applyTheme()
      document.addEventListener('astro:after-swap', applyTheme)
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Lee Palacios" />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@vitualizz" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={twitterImage} />
    <meta name="twitter:image:alt" content={pageTitle} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href={bricolageUrl}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={dmSansUrl}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="cosmos"></div>
    <div class="stars"></div>
    <div class="stars2"></div>
    <div class="stars3"></div>
    <GlobalSpotlight />
    <div class="relative z-[1]">
      <slot />
    </div>
    <script>
      function spawnCats() {
        if (document.querySelector('.walking-cat')) return
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches)
          return
        function spawn(cls: string, inner: string, delay?: string) {
          const el = document.createElement('div')
          el.className = cls
          el.setAttribute('aria-hidden', 'true')
          el.innerHTML = inner
          document.body.appendChild(el)
          if (delay) el.style.animationDelay = delay
        }
        spawn('walking-cat', '<span class="cat-emoji">🐈</span>')
        spawn('peeking-cat', '🐱', '-6s')
      }
      spawnCats()
      document.addEventListener('astro:after-swap', spawnCats)
    </script>
  </body>
</html>
