---
import BaseLayout from './BaseLayout.astro'
import Navbar from '@components/Navbar.astro'
import Footer from 'src/components/Footer.astro'
import AskAiSidebar from 'src/components/blog/AskAiSidebar.astro'
import { Image } from 'astro:assets'
import { useTranslation } from 'src/i18n/utils'
import type { ImageMetadata } from 'astro'

interface NavPost {
  slug: string
  title: string
  tags: string[]
}

interface MorePost extends NavPost {
  date: Date
  readingTime: number
}

interface Props {
  title: string
  shortDescription: string
  author: string
  date: Date
  tags: string[]
  lang: string
  readingTime: number
  cover?: ImageMetadata
  prevPost?: NavPost | null
  nextPost?: NavPost | null
  morePosts?: MorePost[]
}

const {
  title,
  shortDescription,
  author,
  date,
  tags,
  lang,
  readingTime,
  cover,
  prevPost,
  nextPost,
  morePosts = []
} = Astro.props

const t = useTranslation(lang as 'en' | 'es')
const tBlog = t('blog')

const dateLocale = lang === 'es' ? 'es-PE' : 'en-US'
const formattedDate = date
  .toLocaleDateString(dateLocale, {
    day: 'numeric',
    month: 'long',
    year: 'numeric'
  })
  .toUpperCase()

const tagLabel = tags[0]?.toUpperCase() ?? ''
const authorInitial = author.charAt(0).toUpperCase()

const shareUrl = encodeURIComponent(Astro.url.toString())
const shareText = encodeURIComponent(`${title} — por @vitualizz`)
const twitterUrl = `https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`

const suggestions =
  lang === 'es'
    ? [
        'Resúmeme el post en 3 líneas',
        '¿Cuál es el punto más importante?',
        '¿Cómo aplicar esto en producción?'
      ]
    : [
        'Summarize in 3 lines',
        "What's the most important point?",
        'How to apply this in production?'
      ]
---

<BaseLayout title={`Lee Palacios - ${title}`}>
  <!-- Reading progress bar -->
  <div
    id="read-progress"
    aria-hidden="true"
    class="from-accent to-coral pointer-events-none fixed top-0 left-0 z-[100] h-[3px] w-0 bg-gradient-to-r transition-[width] duration-100"
  >
  </div>

  <Navbar />

  <div class="mx-auto max-w-[var(--max)] px-[var(--gutter)]">
    <div
      class="grid grid-cols-1 items-start justify-center gap-x-[clamp(32px,4vw,64px)] py-[clamp(36px,6vw,80px)] pb-[clamp(32px,5vw,64px)] min-[1080px]:grid-cols-[minmax(0,720px)_320px]"
    >
      <article class="blog-article max-w-[720px] min-w-0">
        <!-- Back link -->
        <a
          href={`/${lang}/blog`}
          class="text-muted-custom hover:text-accent mb-8 inline-block font-mono text-[11px] tracking-[0.08em] uppercase transition-colors"
        >
          ← {tBlog.back_to_blog}
        </a>

        <!-- Cover image -->
        {
          cover && (
            <figure class="article-cover border-line bg-bg-2 relative mb-7 aspect-[1200/630] overflow-hidden rounded-[18px] border shadow-[0_24px_60px_rgba(0,0,0,0.35)]">
              <Image
                src={cover}
                alt={title}
                width={1200}
                height={630}
                loading="eager"
                decoding="async"
                class="block h-full w-full object-cover"
              />
            </figure>
          )
        }

        <!-- Header -->
        <header>
          <div class="mb-6 flex flex-wrap items-center gap-2.5">
            {
              tagLabel && (
                <span class="tag-pill text-accent border-accent/30 bg-accent/10 rounded-full border px-2.5 py-1 font-mono text-[11px] font-semibold tracking-[0.08em] uppercase">
                  {tagLabel}
                </span>
              )
            }
            {
              tagLabel && (
                <span class="text-muted-custom font-mono text-[11px] opacity-50">
                  •
                </span>
              )
            }
            <time
              class="text-muted-custom font-mono text-[11px] tracking-[0.06em] uppercase"
              >{formattedDate}</time
            >
            <span class="text-muted-custom font-mono text-[11px] opacity-50"
              >•</span
            >
            <span
              class="text-muted-custom font-mono text-[11px] tracking-[0.06em] uppercase"
              >{readingTime} {tBlog.min_read}</span
            >
          </div>

          <h1
            class="display-title font-display text-ink mt-2 mb-5 text-[clamp(2.5rem,calc(4vw+1rem),4.25rem)] leading-[1.05] font-extrabold tracking-tight"
            style="text-wrap: balance"
          >
            {title}
          </h1>

          <p
            class="subtitle text-ink-soft mb-8 max-w-[56ch] text-[clamp(1.05rem,calc(1vw+0.85rem),1.25rem)] leading-[1.55]"
            style="text-wrap: pretty"
          >
            {shortDescription}
          </p>

          <div
            class="border-line mb-0 flex items-center gap-3.5 border-t border-b py-5"
          >
            <div
              class="from-accent to-coral/60 font-display flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-gradient-to-br text-xl font-extrabold text-[#0b0c10]"
            >
              {authorInitial}
            </div>
            <div class="flex flex-col gap-0.5">
              <div class="text-ink text-[0.9rem] font-semibold">{author}</div>
              <div
                class="text-muted-custom font-mono text-[0.7rem] tracking-[0.04em]"
              >
                Senior Fullstack · AI Builder · Lima 🇵🇪
              </div>
            </div>
          </div>
        </header>

        <!-- Section divider -->
        <div class="my-10 text-center" aria-hidden="true">
          <span
            class="div-mark font-display text-accent relative px-3 text-[22px] tracking-[0.3em] opacity-80"
            >§</span
          >
        </div>

        <!-- Prose body -->
        <div class="prose prose-invert prose-headings:no-underline max-w-none">
          <slot />
        </div>

        <!-- Follow card -->
        <aside class="follow-card" aria-label={tBlog.follow_label}>
          <div class="follow-card__avatar" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
              <path
                d="M2 21h18v-2H2v2zm16-9.5V8a6 6 0 0 0-12 0v3.5L4 14v6h16v-6l-2-2.5zM10 8a2 2 0 0 1 4 0v3.5h-4V8z"
              ></path>
            </svg>
          </div>
          <div class="follow-card__text">
            <span class="follow-card__eyebrow">{tBlog.follow_label}</span>
            <h3 class="follow-card__title">{tBlog.follow_title}</h3>
            <p class="follow-card__body">{tBlog.follow_body}</p>
          </div>
          <div class="follow-card__ctas">
            <a
              class="follow-card__cta follow-card__cta--github"
              href="https://www.github.com/vitualizz"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
            >
              <svg
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-2.1c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.68 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.18-1.49 3.14-1.18 3.14-1.18.63 1.59.23 2.76.12 3.05.74.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.05.78 2.12v3.14c0 .31.21.66.79.55A11.51 11.51 0 0 0 23.5 12c0-6.35-5.15-11.5-11.5-11.5z"
                ></path></svg
              >
              <span>{tBlog.follow_github}</span>
            </a>
            <a
              class="follow-card__cta follow-card__cta--linkedin"
              href="https://www.linkedin.com/in/vitualizz/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
            >
              <svg
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="currentColor"
                aria-hidden="true"
                ><path
                  d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z"
                ></path></svg
              >
              <span>{tBlog.follow_linkedin}</span>
            </a>
          </div>
        </aside>

        <!-- Share footer -->
        <footer class="border-line mt-10 border-t pt-8">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <span
              class="text-muted-custom font-mono text-[12px] tracking-[0.06em] uppercase"
            >
              {lang === 'es' ? '¿Te sirvió?' : 'Was this helpful?'}
            </span>
            <div class="flex flex-wrap gap-2">
              <a
                href={twitterUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="border-line text-ink-soft bg-bg-2/80 hover:border-accent hover:text-accent inline-flex items-center gap-2 rounded-full border px-4 py-2.5 font-mono text-[13px] transition-all hover:-translate-y-0.5"
              >
                <svg
                  viewBox="0 0 24 24"
                  width="14"
                  height="14"
                  fill="currentColor"
                >
                  <path
                    d="M22.46 6c-.77.35-1.6.58-2.46.69a4.28 4.28 0 0 0 1.88-2.37 8.59 8.59 0 0 1-2.72 1.04 4.28 4.28 0 0 0-7.4 3.9 12.13 12.13 0 0 1-8.8-4.46 4.28 4.28 0 0 0 1.32 5.71 4.27 4.27 0 0 1-1.94-.54v.05a4.28 4.28 0 0 0 3.43 4.2 4.3 4.3 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.97 8.59 8.59 0 0 1-5.32 1.83A8.7 8.7 0 0 1 0 18.94a12.1 12.1 0 0 0 6.56 1.92c7.88 0 12.19-6.52 12.19-12.18 0-.19 0-.37-.01-.55A8.7 8.7 0 0 0 22.46 6z"
                  ></path>
                </svg>
                {lang === 'es' ? 'Compartir' : 'Share'}
              </a>
              <a
                href={`/${lang}#contact`}
                class="border-line text-ink-soft bg-bg-2/80 hover:border-accent hover:text-accent inline-flex items-center gap-2 rounded-full border px-4 py-2.5 font-mono text-[13px] transition-all hover:-translate-y-0.5"
              >
                <svg
                  viewBox="0 0 24 24"
                  width="14"
                  height="14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                  <polyline points="3,7 12,13 21,7"></polyline>
                </svg>
                {lang === 'es' ? 'Escríbeme' : 'Contact'}
              </a>
            </div>
          </div>
        </footer>
      </article>

      <AskAiSidebar
        tag={tagLabel}
        postTitle={title}
        postSubtitle={shortDescription}
        suggestions={suggestions}
      />
    </div>

    <!-- Post navigation -->
    {
      (prevPost || nextPost) && (
        <nav class="post-nav mx-auto grid max-w-[720px] grid-cols-1 gap-[14px] pb-16 min-[640px]:grid-cols-2">
          {prevPost ? (
            <a
              href={`/${lang}/blog/${prevPost.slug}`}
              class="pn-card border-line bg-bg-2 hover:border-accent/40 hover:bg-accent/5 flex flex-col gap-1.5 rounded-[16px] border p-[18px_20px] transition-[border-color,transform,background] duration-[250ms] hover:-translate-y-[3px]"
            >
              <span class="text-accent font-mono text-[11px] tracking-[0.06em] uppercase">
                {tBlog.post_nav_prev}
              </span>
              <span class="font-display text-ink text-[16px] leading-[1.3] font-semibold tracking-[-0.015em]">
                {prevPost.title}
              </span>
              <span class="text-muted-custom font-mono text-[10.5px] tracking-[0.05em] uppercase">
                {prevPost.tags[0]}
              </span>
            </a>
          ) : (
            <div />
          )}
          {nextPost ? (
            <a
              href={`/${lang}/blog/${nextPost.slug}`}
              class="pn-card border-line bg-bg-2 hover:border-accent/40 hover:bg-accent/5 flex flex-col gap-1.5 rounded-[16px] border p-[18px_20px] text-right transition-[border-color,transform,background] duration-[250ms] hover:-translate-y-[3px] max-[639px]:text-left"
            >
              <span class="text-accent font-mono text-[11px] tracking-[0.06em] uppercase">
                {tBlog.post_nav_next}
              </span>
              <span class="font-display text-ink text-[16px] leading-[1.3] font-semibold tracking-[-0.015em]">
                {nextPost.title}
              </span>
              <span class="text-muted-custom font-mono text-[10.5px] tracking-[0.05em] uppercase">
                {nextPost.tags[0]}
              </span>
            </a>
          ) : (
            <div />
          )}
        </nav>
      )
    }
  </div>

  <!-- More posts -->
  {
    morePosts.length > 0 && (
      <section class="more-posts border-line border-t">
        <div class="mx-auto max-w-[var(--max)] px-[var(--gutter)] pt-14 pb-20">
          <div class="mb-7 flex flex-wrap items-baseline gap-4">
            <span class="text-accent font-mono text-[12px] tracking-[0.08em] uppercase">
              {tBlog.more_posts_eyebrow}
            </span>
            <h3 class="font-display m-0 text-[clamp(24px,3vw,32px)] font-bold tracking-[-0.025em]">
              {tBlog.more_posts_title}
            </h3>
          </div>
          <div class="grid grid-cols-1 gap-4 min-[820px]:grid-cols-3">
            {morePosts.map((p) => {
              const d = p.date.toLocaleDateString(
                lang === 'es' ? 'es-PE' : 'en-US',
                {
                  day: 'numeric',
                  month: 'short',
                  year: 'numeric'
                }
              )
              return (
                <a
                  href={`/${lang}/blog/${p.slug}`}
                  class="mp-card bg-bg-2 border-line hover:border-accent/40 flex flex-col gap-2 rounded-[16px] border p-[22px] transition-[transform,border-color] duration-300 hover:-translate-y-[4px]"
                >
                  <span class="text-accent border-accent/30 bg-accent/8 self-start rounded-full border px-2 py-0.5 font-mono text-[11px] tracking-[0.06em] uppercase">
                    {p.tags[0]}
                  </span>
                  <h4 class="font-display my-1 text-[17px] leading-[1.25] font-semibold tracking-[-0.015em]">
                    {p.title}
                  </h4>
                  <span class="text-muted-custom mt-auto font-mono text-[11px] tracking-[0.05em] uppercase">
                    {d} · {p.readingTime} {tBlog.min_read}
                  </span>
                </a>
              )
            })}
          </div>
        </div>
      </section>
    )
  }

  <Footer lang={lang as 'en' | 'es'} />
</BaseLayout>

<script>
  const bar = document.getElementById('read-progress')
  if (bar) {
    function updateProgress() {
      const docHeight =
        document.documentElement.scrollHeight - window.innerHeight
      if (docHeight <= 0) return
      ;(bar as HTMLElement).style.width =
        Math.min(100, (window.scrollY / docHeight) * 100) + '%'
    }
    window.addEventListener('scroll', updateProgress, { passive: true })
    updateProgress()
  }
</script>

<style>
  /* Section divider with lines */
  .div-mark::before,
  .div-mark::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--line));
  }
  .div-mark::before {
    right: 100%;
    transform: translateY(-50%) scaleX(-1);
  }
  .div-mark::after {
    left: 100%;
    transform: translateY(-50%);
  }

  /* Cover pseudo-element overlay — cannot be Tailwind */
  .article-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 70%,
      color-mix(in oklab, var(--bg) 80%, transparent)
    );
    pointer-events: none;
  }

  /* Prose slot overrides — :global needed for slot content */
  article :global(.prose h1),
  article :global(.prose h2),
  article :global(.prose h3),
  article :global(.prose h4),
  article :global(.prose h5),
  article :global(.prose h6) {
    font-family: var(--font-display);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  article :global(.prose a) {
    color: var(--accent);
  }

  article :global(.prose code) {
    color: var(--accent);
    background: var(--bg-2);
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
  }

  article :global(.prose pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  /* Follow card */
  .follow-card {
    position: relative;
    margin-top: 48px;
    background: color-mix(in oklab, var(--bg-2) 90%, var(--accent));
    border: 1px solid color-mix(in oklab, var(--accent) 25%, var(--line));
    border-radius: 20px;
    padding: 28px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 64px 1fr;
    grid-template-rows: auto auto;
    gap: 0 20px;
    align-items: start;
  }
  .follow-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--accent),
      var(--coral),
      transparent
    );
  }
  .follow-card__avatar {
    grid-column: 1;
    grid-row: 1;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in oklab, var(--accent) 18%, var(--bg-2));
    color: var(--accent);
    border: 1px solid color-mix(in oklab, var(--accent) 35%, var(--line));
  }
  .follow-card__text {
    grid-column: 2;
  }
  .follow-card__eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 6px;
  }
  .follow-card__title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 10px;
    line-height: 1.2;
  }
  .follow-card__body {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }
  .follow-card__ctas {
    grid-column: 1 / -1;
    margin-top: 20px;
    display: flex;
    flex-direction: row;
    gap: 12px;
    flex-wrap: wrap;
  }
  .follow-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    height: 44px;
    padding: 0 20px;
    border-radius: 12px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14.5px;
    letter-spacing: -0.005em;
    text-decoration: none;
    transition:
      transform 0.2s,
      box-shadow 0.2s,
      background 0.2s,
      border-color 0.2s;
    flex: 1 1 220px;
    min-width: 0;
  }
  .follow-card__cta--github {
    background: var(--bg-2);
    color: var(--ink);
    border: 1px solid var(--line);
  }
  .follow-card__cta--github:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 22px color-mix(in oklab, var(--accent) 25%, transparent);
  }
  .follow-card__cta--linkedin {
    background: #0a66c2;
    color: #fff;
    border: 1px solid transparent;
  }
  .follow-card__cta--linkedin:hover {
    background: #0d7dd6;
    transform: translateY(-2px);
    box-shadow: 0 8px 22px color-mix(in oklab, #0a66c2 45%, transparent);
  }
  .follow-card__cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
