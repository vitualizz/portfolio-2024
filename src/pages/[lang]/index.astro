---
import { getCollection } from 'astro:content'
import HomeLayout from 'src/layouts/HomeLayout.astro'
import PresentationSection from 'src/components/PresentationSection.astro'
import AboutMeSection from 'src/components/AboutMeSection.astro'
import AskAISection from 'src/components/AskAISection.astro'
import ProjectsSection from 'src/components/ProjectsSection.astro'
import WorkExperienceSection from 'src/components/WorkExperienceSection.astro'
import BlogSection from 'src/components/BlogSection.astro'
import ContactMeSection from 'src/components/ContactMeSection.astro'
import ResumePreviewModal from 'src/components/ResumePreviewModal.astro'
import { getLangFromUrl } from 'src/i18n/utils'
import { LANG_CODES } from 'src/i18n/constants'

export const prerender = true

export function getStaticPaths() {
  return LANG_CODES.map((lang) => ({ params: { lang } }))
}

const lang = getLangFromUrl(Astro.url)
const allPosts = await getCollection('blog')
const posts = allPosts
  .filter(p => p.data.lang === lang)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<HomeLayout lang={lang}>
  <homepage-spotlight class="homepage-shell">
    <div id="pageSpotlight" class="page-spotlight" aria-hidden="true"></div>
    <main class="relative z-[1]">
      <PresentationSection lang={lang} />
      <AboutMeSection lang={lang} />
      <AskAISection lang={lang} />
      <ProjectsSection />
      <WorkExperienceSection />
      <BlogSection posts={posts} lang={lang} />
      <ContactMeSection lang={lang} />
      <ResumePreviewModal lang={lang} />
    </main>
  </homepage-spotlight>
</HomeLayout>

<style>
  .homepage-shell {
    position: relative;
    isolation: isolate;
    display: block;
  }

  .page-spotlight {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(
        560px circle at var(--page-glow-x, 50vw) var(--page-glow-y, 42vh),
        color-mix(in oklab, var(--accent) 13%, transparent),
        color-mix(in oklab, var(--coral) 5%, transparent) 38%,
        transparent 72%
      );
    opacity: 0;
    transition: opacity 0.45s ease;
    will-change: opacity, background;
  }

  .page-spotlight.is-glow-active {
    opacity: 0.82;
  }

  [data-theme='light'] .page-spotlight {
    background:
      radial-gradient(
        520px circle at var(--page-glow-x, 50vw) var(--page-glow-y, 42vh),
        color-mix(in oklab, var(--accent) 8%, transparent),
        color-mix(in oklab, var(--coral) 3%, transparent) 42%,
        transparent 74%
      );
  }

  [data-theme='light'] .page-spotlight.is-glow-active {
    opacity: 0.5;
  }

  @media (prefers-reduced-motion: reduce), (hover: none) {
    .page-spotlight {
      display: none;
    }
  }
</style>

<script>
  import { initViewportPointerGlow } from 'src/scripts/pointerGlow'

  class HomepageSpotlightElement extends HTMLElement {
    private cleanupSpotlight: () => void = () => {}

    connectedCallback() {
      this.cleanup()
      const spotlight = this.querySelector<HTMLElement>('#pageSpotlight')
      if (spotlight) this.cleanupSpotlight = initViewportPointerGlow(spotlight)
    }

    disconnectedCallback() {
      this.cleanup()
    }

    private cleanup() {
      this.cleanupSpotlight()
      this.cleanupSpotlight = () => {}
    }
  }

  if (!customElements.get('homepage-spotlight')) {
    customElements.define('homepage-spotlight', HomepageSpotlightElement)
  }
</script>
