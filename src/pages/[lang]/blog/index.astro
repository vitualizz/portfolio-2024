---
import { getCollection } from 'astro:content'
import HomeLayout from 'src/layouts/HomeLayout.astro'
import { getLangFromUrl, useTranslation } from 'src/i18n/utils.ts'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
const tBlog = t('blog')
const allPosts = await getCollection('blog', (filter) => {
  return lang === filter.data.lang
})

const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)
---

<HomeLayout>
  <main class="px-6 lg:px-16 py-24 max-w-6xl mx-auto">
    <div class="mb-16 anim-fade-up">
      <h1 class="font-display text-5xl lg:text-6xl font-bold mb-4">Blog</h1>
      <div class="w-16 h-1 bg-accent rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        posts.map((post, i) => (
          <a
            href={`/${lang}/blog/${post.slug.split('/')[0]}`}
            class="group block anim-fade-up"
            style={`animation-delay: ${i * 0.1}s`}
          >
            <article class="h-full rounded-xl border border-border bg-surface p-6 flex flex-col gap-4 hover:border-accent/50 transition-colors duration-300">
              <time class="text-sm text-text-muted font-medium">
                {new Date(post.data.date).toLocaleDateString(
                  lang === 'en' ? 'en-US' : 'es-ES',
                  { year: 'numeric', month: 'long', day: 'numeric' }
                )}
              </time>

              <h2 class="font-display text-xl lg:text-2xl font-semibold group-hover:text-accent transition-colors leading-tight">
                {post.data.title}
              </h2>

              {post.data.shortDescription && (
                <p class="text-text-muted text-sm leading-relaxed flex-1">
                  {post.data.shortDescription}
                </p>
              )}

              <div class="flex items-center gap-1 text-accent text-sm font-medium mt-auto">
                <span>{tBlog.read_more}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </main>
</HomeLayout>
