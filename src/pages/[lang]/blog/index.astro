---
import { getCollection } from 'astro:content'
import HomeLayout from 'src/layouts/HomeLayout.astro'
import { getLangFromUrl, useTranslation } from 'src/i18n/utils.ts'
import { Image } from 'astro:assets'
import { BLOG_DATE_LOCALE, withLangPath } from 'src/i18n/constants'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
const tBlog = t('blog')

const allPosts = await getCollection(
  'blog',
  (filter) => filter.data.lang === lang
)
const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)

const primaryTagCounts: Record<string, number> = {}
for (const post of posts) {
  const tag = post.data.tags[0]
  if (tag) primaryTagCounts[tag] = (primaryTagCounts[tag] || 0) + 1
}
const uniquePrimaryTags = Object.keys(primaryTagCounts)

function formatTag(tag: string): string {
  return tag
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ')
}

function getReadingTime(body: string): number {
  return Math.max(1, Math.ceil(body.split(/\s+/).filter(Boolean).length / 200))
}
---

<HomeLayout lang={lang as 'en' | 'es'}>
  <main
    class="mx-auto max-w-[var(--max)] px-[var(--gutter)] py-[clamp(40px,6vw,80px)]"
  >
    <!-- ===== HERO ===== -->
    <section class="blog-hero">
      <div>
        <!-- Eyebrow -->
        <div
          class="text-accent mb-[22px] inline-flex items-center gap-2.5 rounded-full border border-[color-mix(in_oklab,var(--accent)_30%,transparent)] bg-[color-mix(in_oklab,var(--accent)_10%,transparent)] px-3.5 py-1.5 font-mono text-[12px] tracking-[0.08em] uppercase"
        >
          <span class="bh-live" aria-hidden="true"></span>
          {tBlog.index_eyebrow}
        </div>

        <!-- Title -->
        <h1
          class="font-display mb-[18px] text-[clamp(42px,7vw,84px)] leading-none font-extrabold tracking-[-0.035em] text-balance"
        >
          <span set:html={tBlog.index_title} /><span
            class="bh-cat-emoji"
            aria-hidden="true">🐱</span
          >
        </h1>

        <!-- Subtitle -->
        <p
          class="text-ink-soft mb-6 max-w-[56ch] text-[clamp(16px,1.4vw,18px)] leading-[1.65]"
        >
          {tBlog.index_subtitle}
        </p>

        <!-- Stats -->
        <div
          class="border-line inline-flex overflow-hidden rounded-[14px] border bg-[color-mix(in_oklab,var(--bg-2)_80%,transparent)]"
        >
          <div class="border-line border-r px-[22px] py-3.5 text-center">
            <span
              class="font-display text-accent block text-[26px] leading-none font-bold"
              >{posts.length}</span
            >
            <span
              class="text-muted-custom mt-[5px] block font-mono text-[10.5px] tracking-[0.05em] uppercase"
              >{tBlog.index_stat_posts}</span
            >
          </div>
          <div class="border-line border-r px-[22px] py-3.5 text-center">
            <span
              class="font-display text-accent block text-[26px] leading-none font-bold"
              >{uniquePrimaryTags.length}</span
            >
            <span
              class="text-muted-custom mt-[5px] block font-mono text-[10.5px] tracking-[0.05em] uppercase"
              >{tBlog.index_stat_topics}</span
            >
          </div>
          <div class="px-[22px] py-3.5 text-center">
            <span
              class="font-display text-accent block text-[26px] leading-none font-bold"
              >3</span
            >
            <span
              class="text-muted-custom mt-[5px] block font-mono text-[10.5px] tracking-[0.05em] uppercase"
              >{tBlog.index_stat_cats}</span
            >
          </div>
        </div>
      </div>

      <!-- Cat island art -->
      <div class="bh-art" aria-hidden="true">
        <div class="bh-island">🐈‍⬛</div>
        <span class="bh-paw bh-paw-1">🐾</span>
        <span class="bh-paw bh-paw-2">🐾</span>
        <div class="bh-scrap bh-scrap-1"><b>SELECT</b> * FROM gatos</div>
        <div class="bh-scrap bh-scrap-2">
          <b>// TODO:</b>
          {lang === 'es' ? 'dar croquetas' : 'feed cats'}
        </div>
        <div class="bh-scrap bh-scrap-3">EXPLAIN <b>ANALYZE</b></div>
        <div class="bh-scrap bh-scrap-4">git commit -m "<b>meow</b>"</div>
      </div>
    </section>

    <!-- ===== FILTER BAR ===== -->
    <div
      id="blogFilter"
      class="border-line sticky top-[84px] z-20 mb-7 flex flex-wrap items-center gap-2.5 rounded-2xl border bg-[color-mix(in_oklab,var(--bg-2)_80%,transparent)] px-[22px] py-[18px] backdrop-blur-xl"
    >
      <span
        class="text-muted-custom mr-1 font-mono text-[11px] tracking-[0.06em] uppercase"
        >{tBlog.filter_label}</span
      >

      <button class="bf-chip bf-chip-active" data-filter="all" aria-pressed="true">
        {tBlog.filter_all}
        <span class="font-mono text-[10.5px] opacity-65">{posts.length}</span>
      </button>

      {
        uniquePrimaryTags.map((tag) => (
          <button class="bf-chip" data-filter={tag} aria-pressed="false">
            {formatTag(tag)}
            <span class="font-mono text-[10.5px] opacity-65">
              {primaryTagCounts[tag]}
            </span>
          </button>
        ))
      }

      <label
        class="bf-search-label border-line bg-bg ml-auto flex min-w-[180px] flex-1 items-center gap-2 rounded-full border px-3.5 py-2 transition-colors duration-200"
        aria-label={lang === 'es' ? 'Buscar' : 'Search'}
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-muted-custom h-3.5 w-3.5 shrink-0"
          ><circle cx="11" cy="11" r="7"></circle><line
            x1="21"
            y1="21"
            x2="16.5"
            y2="16.5"></line></svg
        >
        <input
          id="bfSearch"
          type="search"
          placeholder={tBlog.filter_search_placeholder}
          class="text-ink placeholder:text-muted-custom min-w-0 flex-1 border-none bg-transparent font-sans text-[13.5px] outline-none"
        />
      </label>
    </div>

    <!-- ===== POSTS GRID ===== -->
    <div
      id="postsGrid"
      class="grid grid-cols-1 gap-5 min-[640px]:grid-cols-2 min-[1080px]:grid-cols-3"
    >
      {
        posts.map((post, i) => {
          const slug = post.slug.split('/')[0]
          const isFeatured = i === 0
          const tag = post.data.tags[0] || ''
          const dateFormatted = post.data.date.toLocaleDateString(
            BLOG_DATE_LOCALE[lang as 'en' | 'es'],
            { day: 'numeric', month: 'short', year: 'numeric' }
          )
          const readingTime = getReadingTime(post.body ?? '')

          return (
            <a
              href={`/${lang}/blog/${slug}`}
              class:list={[
                'bp-card',
                isFeatured && 'bp-featured min-[640px]:col-span-2'
              ]}
              data-tags={post.data.tags.join(',')}
              data-title={post.data.title.toLowerCase()}
              data-excerpt={(post.data.shortDescription || '').toLowerCase()}
            >
              <div class:list={['bp-cover', isFeatured && 'bp-cover-featured']}>
                {isFeatured && (
                  <span class="bp-pin">⌘ {tBlog.featured_label}</span>
                )}
                {post.data.cover && (
                  <Image
                    src={post.data.cover}
                    alt=""
                    width={isFeatured ? 1200 : 800}
                    height={isFeatured ? 630 : 450}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    class="bp-cover-img h-full w-full object-cover"
                  />
                )}
              </div>

              <div class="flex flex-1 flex-col px-6 pt-[22px] pb-6">
                <div class="text-muted-custom mb-3.5 flex flex-wrap items-center gap-2.5 font-mono text-[11px] tracking-[0.05em] uppercase">
                  {tag && (
                    <span class="text-accent rounded-full border border-[color-mix(in_oklab,var(--accent)_35%,var(--line))] bg-[color-mix(in_oklab,var(--accent)_8%,transparent)] px-2.5 py-[3px] font-semibold">
                      {formatTag(tag)}
                    </span>
                  )}
                  <span>{dateFormatted}</span>
                  <span class="bp-dot" />
                  <span>
                    {readingTime} {tBlog.min_read}
                  </span>
                </div>

                <h3
                  class:list={[
                    'font-display mb-2.5 leading-[1.18] font-bold tracking-[-0.02em] text-balance',
                    isFeatured
                      ? 'text-[clamp(26px,3vw,34px)]'
                      : 'text-[clamp(20px,2vw,24px)]'
                  ]}
                >
                  {post.data.title}
                </h3>

                <p class="text-ink-soft mb-[18px] flex-1 text-[14.5px] leading-[1.6]">
                  {post.data.shortDescription}
                </p>

                <div class="text-accent mt-auto flex items-center justify-between font-mono text-[12px]">
                  <span>{tBlog.read_article}</span>
                  <span class="bp-arrow transition-transform duration-[250ms]">
                    ↗
                  </span>
                </div>
              </div>
            </a>
          )
        })
      }

      <!-- Empty state -->
      <div
        id="emptyState"
        class="border-line col-span-full hidden rounded-[18px] border border-dashed bg-[color-mix(in_oklab,var(--bg-2)_60%,transparent)] px-6 py-[60px] text-center"
      >
        <div class="e-cat mb-3.5 inline-block text-[56px] leading-none">🙀</div>
        <h4
          class="font-display mb-1.5 text-[22px] font-bold tracking-[-0.02em]"
        >
          {tBlog.empty_title}
        </h4>
        <p class="text-muted-custom text-[14px]">{tBlog.empty_text}</p>
      </div>
    </div>

    <!-- ===== CLOSING SECTION ===== -->
    <section
      class="blog-closer relative mt-[clamp(56px,8vw,88px)] overflow-hidden rounded-[24px] border border-[color-mix(in_oklab,var(--accent)_30%,var(--line))] p-[clamp(36px,5vw,60px)] text-center"
    >
      <h2
        class="font-display relative mb-3.5 text-[clamp(28px,4vw,40px)] leading-[1.05] font-bold tracking-[-0.03em] text-balance"
        set:html={tBlog.closer_title}
      />
      <p
        class="text-ink-soft relative mx-auto mb-7 max-w-[56ch] text-[16px] leading-[1.65]"
      >
        {tBlog.closer_text}
      </p>
      <div class="relative inline-flex flex-wrap justify-center gap-3">
        <a
          href="https://github.com/vitualizz"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-accent inline-flex items-center gap-2.5 rounded-full px-[22px] py-[13px] text-[14.5px] font-semibold text-[#0B0C10] transition-[transform,box-shadow] duration-200 hover:-translate-y-0.5 hover:shadow-[0_12px_32px_color-mix(in_oklab,var(--accent)_40%,transparent)]"
        >
          {tBlog.closer_github}
        </a>
        <a
          href={withLangPath(lang as 'en' | 'es', '#contact')}
          class="border-line text-ink hover:border-accent inline-flex items-center gap-2.5 rounded-full border bg-[color-mix(in_oklab,var(--bg)_50%,transparent)] px-[22px] py-[13px] text-[14.5px] font-medium transition-[border-color,transform] duration-200 hover:-translate-y-0.5"
        >
          {tBlog.closer_contact}
        </a>
      </div>
    </section>

    <!-- ===== MASCOT ROW ===== -->
    <div
      class="text-muted-custom mt-10 mb-8 flex items-center justify-center gap-4 font-mono text-[12px] tracking-[0.05em] uppercase"
    >
      <span class="sleeping-cat">
        <span class="body">😺</span>
        <span class="zzz"><span>Z</span><span>z</span><span>z</span></span>
      </span>
      <span>{tBlog.mascot_text}</span>
    </div>
  </main>
</HomeLayout>

<style>
  /* ===== BLOG HERO ===== */
  .blog-hero {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
    margin-bottom: clamp(40px, 6vw, 64px);
  }
  @media (max-width: 820px) {
    .blog-hero {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  /* Live dot */
  .bh-live {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--mint);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--mint) 25%, transparent);
    animation: bh-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes bh-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 4px color-mix(in oklab, var(--mint) 25%, transparent);
    }
    50% {
      box-shadow: 0 0 0 7px color-mix(in oklab, var(--mint) 10%, transparent);
    }
  }

  /* Cat emoji tilt */
  .bh-cat-emoji {
    display: inline-block;
    font-size: 0.7em;
    margin-left: 8px;
    animation: bh-cat-tilt 4s ease-in-out infinite;
    transform-origin: bottom center;
  }
  @keyframes bh-cat-tilt {
    0%,
    100% {
      transform: rotate(-4deg);
    }
    50% {
      transform: rotate(8deg);
    }
  }

  /* Cat island */
  .bh-art {
    position: relative;
    aspect-ratio: 1 / 1;
    max-width: 360px;
    width: 100%;
    margin-left: auto;
    background: radial-gradient(
      circle at 50% 60%,
      color-mix(in oklab, var(--accent) 20%, transparent) 0%,
      transparent 60%
    );
    border-radius: 50%;
  }
  @media (max-width: 820px) {
    .bh-art {
      max-width: 280px;
      margin: 0 auto;
    }
  }
  .bh-island {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 130px;
    line-height: 1;
    animation: bh-island-float 6s ease-in-out infinite;
  }
  @keyframes bh-island-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  .bh-scrap {
    position: absolute;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--ink);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.35);
    white-space: nowrap;
  }
  .bh-scrap :global(b) {
    color: var(--accent);
  }
  .bh-scrap-1 {
    top: 12%;
    left: -4%;
    --r: -8deg;
    transform: rotate(-8deg);
    animation: bh-scrap-float 5s ease-in-out infinite;
  }
  .bh-scrap-2 {
    top: 18%;
    right: -2%;
    --r: 6deg;
    transform: rotate(6deg);
    animation: bh-scrap-float 5.5s ease-in-out infinite 1.2s;
  }
  .bh-scrap-3 {
    bottom: 14%;
    left: 4%;
    --r: 4deg;
    transform: rotate(4deg);
    animation: bh-scrap-float 6s ease-in-out infinite 0.6s;
  }
  .bh-scrap-4 {
    bottom: 8%;
    right: 6%;
    --r: -6deg;
    transform: rotate(-6deg);
    animation: bh-scrap-float 5.8s ease-in-out infinite 2.1s;
  }
  @keyframes bh-scrap-float {
    0%,
    100% {
      transform: translate(0, 0) rotate(var(--r, 0deg));
    }
    50% {
      transform: translate(0, -6px) rotate(var(--r, 0deg));
    }
  }
  .bh-paw {
    position: absolute;
    font-size: 18px;
    opacity: 0.35;
  }
  .bh-paw-1 {
    top: 8%;
    left: 30%;
    animation: bh-paw-fade 3s ease-in-out infinite;
  }
  .bh-paw-2 {
    bottom: 26%;
    right: 18%;
    animation: bh-paw-fade 3.2s ease-in-out infinite 0.8s;
  }
  @keyframes bh-paw-fade {
    0%,
    100% {
      transform: scale(0.9) rotate(-15deg);
      opacity: 0;
    }
    50% {
      transform: scale(1) rotate(-15deg);
      opacity: 0.55;
    }
  }

  /* ===== FILTER BAR ===== */
  .bf-search-label:focus-within {
    border-color: var(--accent);
  }
  .bf-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: color-mix(in oklab, var(--bg) 60%, transparent);
    color: var(--ink-soft);
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition:
      border-color 0.2s,
      color 0.2s,
      background 0.2s,
      transform 0.2s;
  }
  .bf-chip:hover {
    border-color: var(--accent);
    color: var(--ink);
    transform: translateY(-1px);
  }
  .bf-chip-active {
    background: var(--accent) !important;
    color: #0b0c10 !important;
    border-color: var(--accent) !important;
    font-weight: 600;
  }

  /* ===== BLOG CARDS ===== */
  .bp-card {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.35s cubic-bezier(0.2, 0.7, 0.3, 1),
      border-color 0.3s,
      box-shadow 0.3s;
    position: relative;
    color: var(--ink);
    text-decoration: none;
  }
  .bp-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in oklab, var(--accent) 40%, var(--line));
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.3);
  }
  .bp-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
    z-index: 2;
  }
  .bp-card:hover::before {
    transform: scaleX(1);
  }

  /* Featured card */
  .bp-featured {
    background: linear-gradient(
      160deg,
      color-mix(in oklab, var(--accent) 12%, var(--bg-2)),
      var(--bg-2) 70%
    );
    border-color: color-mix(in oklab, var(--accent) 30%, var(--line));
  }
  @media (min-width: 640px) {
    .bp-featured {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
    }
  }

  /* Cover */
  .bp-cover {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-3);
    flex-shrink: 0;
  }
  .bp-cover-img {
    display: block;
    transition: transform 0.6s ease;
  }
  .bp-card:hover .bp-cover-img {
    transform: scale(1.04);
  }
  .bp-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 60%,
      color-mix(in oklab, var(--bg) 90%, transparent)
    );
    pointer-events: none;
    z-index: 1;
  }

  /* Featured cover */
  .bp-cover-featured {
    aspect-ratio: unset;
    height: 100%;
    min-height: 280px;
  }
  @media (max-width: 639px) {
    .bp-cover-featured {
      height: auto;
      min-height: 0;
      aspect-ratio: 16 / 9;
    }
  }

  /* Pin badge */
  .bp-pin {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    background: color-mix(in oklab, var(--bg) 80%, transparent);
    backdrop-filter: blur(6px);
    border: 1px solid color-mix(in oklab, var(--accent) 30%, var(--line));
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* Meta separator dot */
  .bp-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--muted);
    flex-shrink: 0;
    display: inline-block;
  }

  /* Arrow hover */
  .bp-card:hover .bp-arrow {
    transform: translate(4px, -4px);
  }

  /* Empty state cat */
  .e-cat {
    animation: bh-cat-tilt 3s ease-in-out infinite;
    transform-origin: bottom center;
    display: inline-block;
  }

  /* ===== CLOSING SECTION ===== */
  .blog-closer {
    background: linear-gradient(
      135deg,
      color-mix(in oklab, var(--accent) 12%, var(--bg-2)),
      var(--bg-2) 60%
    );
  }
  .blog-closer::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -80px;
    width: 360px;
    height: 360px;
    background: var(--accent);
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.2;
    pointer-events: none;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .bh-live,
    .bh-cat-emoji,
    .bh-island,
    .bh-scrap-1,
    .bh-scrap-2,
    .bh-scrap-3,
    .bh-scrap-4,
    .bh-paw-1,
    .bh-paw-2,
    .e-cat {
      animation: none;
    }
    .bp-card:hover {
      transform: none;
    }
    .bp-card:hover .bp-cover-img {
      transform: none;
    }
    .bp-card:hover .bp-arrow {
      transform: none;
    }
  }
</style>

<script>
  const grid = document.getElementById('postsGrid')
  const emptyState = document.getElementById('emptyState')
  const chips = document.querySelectorAll<HTMLButtonElement>('.bf-chip')
  const searchInput = document.getElementById(
    'bfSearch'
  ) as HTMLInputElement | null

  let currentFilter = 'all'
  let currentSearch = ''

  function filterPosts() {
    if (!grid) return
    const q = currentSearch.trim().toLowerCase()
    const cards = grid.querySelectorAll<HTMLElement>('.bp-card')
    let visibleCount = 0

    cards.forEach((card) => {
      const tags = card.dataset.tags?.split(',') ?? []
      const title = card.dataset.title ?? ''
      const excerpt = card.dataset.excerpt ?? ''

      const matchTag = currentFilter === 'all' || tags.includes(currentFilter)
      const matchSearch =
        !q ||
        title.includes(q) ||
        excerpt.includes(q) ||
        tags.some((t) => t.includes(q))

      const visible = matchTag && matchSearch
      card.style.display = visible ? '' : 'none'
      if (visible) visibleCount++
    })

    if (emptyState) {
      if (visibleCount > 0) {
        emptyState.classList.add('hidden')
      } else {
        emptyState.classList.remove('hidden')
      }
    }
  }

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => {
        c.classList.toggle('bf-chip-active', c === chip)
        c.setAttribute('aria-pressed', c === chip ? 'true' : 'false')
      })
      currentFilter = chip.dataset.filter ?? 'all'
      filterPosts()
    })
  })

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value
      filterPosts()
    })
  }
</script>
