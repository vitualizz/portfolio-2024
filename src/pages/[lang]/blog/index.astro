---
import { getCollection } from 'astro:content'
import HomeLayout from 'src/layouts/HomeLayout.astro'
import { getLangFromUrl, useTranslation } from 'src/i18n/utils.ts'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
const tBlog = t('blog')
const allPosts = await getCollection('blog', (filter) => {
  return lang === filter.data.lang
})

const posts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)
---

<HomeLayout lang={lang as 'en' | 'es'}>
  <main class="mx-auto max-w-6xl px-6 py-24 lg:px-16">
    <div class="anim-fade-up mb-16">
      <h1 class="font-display mb-4 text-5xl font-bold lg:text-6xl">Blog</h1>
      <div class="bg-accent h-1 w-16 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post, i) => (
          <a
            href={`/${lang}/blog/${post.slug.split('/')[0]}`}
            class="group anim-fade-up block"
            style={`animation-delay: ${i * 0.1}s`}
          >
            <article class="border-border bg-surface hover:border-accent/50 flex h-full flex-col gap-4 rounded-xl border p-6 transition-colors duration-300">
              <time class="text-text-muted text-sm font-medium">
                {new Date(post.data.date).toLocaleDateString(
                  lang === 'en' ? 'en-US' : 'es-ES',
                  { year: 'numeric', month: 'long', day: 'numeric' }
                )}
              </time>

              <h2 class="font-display group-hover:text-accent text-xl leading-tight font-semibold transition-colors lg:text-2xl">
                {post.data.title}
              </h2>

              {post.data.shortDescription && (
                <p class="text-text-muted flex-1 text-sm leading-relaxed">
                  {post.data.shortDescription}
                </p>
              )}

              <div class="text-accent mt-auto flex items-center gap-1 text-sm font-medium">
                <span>{tBlog.read_more}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </main>
</HomeLayout>
