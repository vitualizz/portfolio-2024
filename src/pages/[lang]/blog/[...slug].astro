---
import BlogPostLayout from 'src/layouts/BlogPostLayout.astro'
import { getCollection, render } from 'astro:content'

const { lang, slug } = Astro.params

const pages = await getCollection('blog')
const post = pages.find((page) => {
  const [pageSlug, pageLang] = page.slug.split('/')
  return pageSlug === slug && pageLang === lang
})

if (!post) {
  return Astro.redirect('/404')
}

const { Content } = await render(post)
const { title, shortDescription, author, date, tags } = post.data

const wordCount = post.body.split(/\s+/).filter(Boolean).length
const readingTime = Math.max(1, Math.ceil(wordCount / 200))
---

<BlogPostLayout
  title={title}
  shortDescription={shortDescription}
  author={author}
  date={date}
  tags={tags}
  lang={lang!}
  readingTime={readingTime}
>
  <Content />
</BlogPostLayout>
