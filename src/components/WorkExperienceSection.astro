---
import { getLangFromUrl } from 'src/i18n/utils'
import { useTranslation } from 'src/i18n/utils'
import experienceData from 'src/data/experience.json'
import { safeI18nHtml } from 'src/components/shared/i18nRichText'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)

const MONTHS_ES = [
  'Ene',
  'Feb',
  'Mar',
  'Abr',
  'May',
  'Jun',
  'Jul',
  'Ago',
  'Sep',
  'Oct',
  'Nov',
  'Dic'
]
const MONTHS_EN = [
  'Jan',
  'Feb',
  'Mar',
  'Apr',
  'May',
  'Jun',
  'Jul',
  'Aug',
  'Sep',
  'Oct',
  'Nov',
  'Dec'
]

function formatPeriod(dateStr: string): string {
  const [year, month] = dateStr.split('-')
  const months = lang === 'es' ? MONTHS_ES : MONTHS_EN
  return `${months[parseInt(month) - 1]} ${year}`
}
---

<section class="s" id="xp">
  <div class="wrap">
    <div class="s-head reveal">
      <span class="s-eyebrow">{t('home').xp_eyebrow}</span>
      <h2 class="s-title" set:html={safeI18nHtml(t('home').xp_title)} />
      <p class="s-sub">{t('home').xp_subtitle}</p>
    </div>

    <div
      class="xp relative flex flex-col"
      style="max-width:880px;margin:0 auto"
    >
      {
        experienceData.map((entry, i) => (
          <div
            class={`xp-item relative grid gap-7 py-[22px] reveal${entry.period.end === null ? ' current' : ''}`}
            style="grid-template-columns:24px 1fr"
          >
            <div class="xp-bullet bg-bg border-accent mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border-2">
              <span class="core bg-accent h-2 w-2 rounded-full" />
            </div>
            <div class="xp-content">
              <div class="mb-1 flex flex-wrap items-baseline gap-3">
                <span class="xp-period text-muted-custom font-mono text-[12px] tracking-[0.05em] uppercase">
                  {formatPeriod(entry.period.start)} —{' '}
                  {entry.period.end === null ? (
                    <span class="text-accent font-medium">
                      {lang === 'es' ? 'Actualidad' : 'Present'}
                    </span>
                  ) : (
                    formatPeriod(entry.period.end)
                  )}
                </span>
              </div>
              <h4 class="my-1 text-[24px] font-bold tracking-[-0.02em]">
                {entry.company}
                {i === experienceData.length - 1 && (
                  <span style="color:var(--muted);font-weight:500;font-size:0.7em;">
                    {' '}
                    — {t('home').paused_label}
                  </span>
                )}
              </h4>
              <div class="text-coral mb-[10px] text-[15px] font-medium">
                {entry.role}
              </div>
              <p
                class="text-ink-soft mb-3 max-w-[60ch] text-[15px] leading-[1.65]"
                set:html={safeI18nHtml(
                  lang === 'es' ? entry.description_es : entry.description_en
                )}
              />
              <div class="text-muted-custom flex flex-wrap gap-[5px] font-mono text-[11px]">
                {entry.tech.map((t) => (
                  <span class="border-line rounded-full border px-2 py-[3px]">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .xp::before {
    content: '';
    position: absolute;
    left: 11px;
    top: 18px;
    bottom: 18px;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), transparent 90%);
    opacity: 0.4;
  }
  .xp-item.current .xp-bullet .core {
    box-shadow: 0 0 0 5px color-mix(in oklab, var(--accent) 30%, transparent);
  }
</style>
