---
import type { ExperienceEntry } from '../types/Experience.types'
import experience from '../data/experience.json'
import { getLangFromUrl, useTranslation } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
const tWx = t('work_experience')

const entries = experience as ExperienceEntry[]
---

<section
  id="work_experience"
  data-section="work_experience"
  class="px-6 lg:px-16 py-32 max-w-6xl mx-auto"
>
  <div class="mb-16 anim-fade-up">
    <h2 class="font-display text-4xl lg:text-5xl font-bold mb-4">{tWx.title}</h2>
    <div class="w-16 h-1 bg-accent rounded-full"></div>
  </div>

  <ol class="relative border-l border-border ml-4">
    {entries.map((entry, i) => (
      <li class="mb-12 ml-10 anim-fade-up" style={`animation-delay: ${i * 0.1}s`}>
        <!-- Timeline dot -->
        <span class="absolute -left-[1.125rem] flex items-center justify-center w-9 h-9 rounded-full bg-bg border-2 border-accent">
          <span class="w-2 h-2 rounded-full bg-accent"></span>
        </span>

        <!-- Period -->
        <time class="block mb-1 text-sm font-medium text-accent">
          {entry.period.start} — {entry.period.end ?? tWx.present}
        </time>

        <!-- Role + Company -->
        <h3 class="font-display text-2xl font-semibold mb-1">{entry.role}</h3>
        <p class="text-text-muted font-medium mb-3">{entry.company}</p>

        <!-- Description -->
        <p class="text-base leading-relaxed mb-4 max-w-2xl">
          {lang === 'en' ? entry.description_en : entry.description_es}
        </p>

        <!-- Tech pills -->
        <ul class="flex flex-wrap gap-2" aria-label="Technologies used">
          {entry.tech.map(tech => (
            <li>
              <span class="text-xs font-medium px-3 py-1 rounded-full bg-surface border border-border text-text-muted">
                {tech}
              </span>
            </li>
          ))}
        </ul>
      </li>
    ))}
  </ol>
</section>
