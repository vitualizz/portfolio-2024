---
import { getLangFromUrl } from 'src/i18n/utils'
import experienceData from 'src/data/experience.json'

const lang = getLangFromUrl(Astro.url)

const MONTHS_ES = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic']
const MONTHS_EN = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']

function formatPeriod(dateStr: string): string {
  const [year, month] = dateStr.split('-')
  const months = lang === 'es' ? MONTHS_ES : MONTHS_EN
  return `${months[parseInt(month) - 1]} ${year}`
}
---

<section class="s" id="xp">
  <div class="wrap">
    <div class="s-head reveal">
      <span class="s-eyebrow">// 04 · Experiencia</span>
      <h2 class="s-title">Mi <span class="y">recorrido</span></h2>
      <p class="s-sub">Cuatro paradas profesionales, una constante: producto que se envía.</p>
    </div>

    <div class="xp">
      {experienceData.map((entry, i) => (
        <div class={`xp-item reveal${entry.period.end === null ? ' current' : ''}`}>
          <div class="xp-bullet"><span class="core"></span></div>
          <div class="xp-content">
            <div class="xp-meta">
              <span class="xp-period">
                {formatPeriod(entry.period.start)} — {
                  entry.period.end === null
                    ? <span class="now">{lang === 'es' ? 'Actualidad' : 'Present'}</span>
                    : formatPeriod(entry.period.end)
                }
              </span>
            </div>
            <h4>{entry.company}{i === experienceData.length - 1 && <span style="color:var(--muted);font-weight:500;font-size:0.7em;"> — pausado</span>}</h4>
            <div class="xp-role">{entry.role}</div>
            <p class="xp-summary" set:html={lang === 'es' ? entry.description_es : entry.description_en} />
            <div class="xp-tech">
              {entry.tech.map(t => <span>{t}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .xp { display: flex; flex-direction: column; max-width: 880px; margin: 0 auto; position: relative; }
  .xp::before { content: ""; position: absolute; left: 11px; top: 18px; bottom: 18px; width: 2px; background: linear-gradient(to bottom, var(--accent), transparent 90%); opacity: .4; }
  .xp-item { display: grid; grid-template-columns: 24px 1fr; gap: 28px; padding: 22px 0; position: relative; }
  .xp-bullet { @apply bg-bg border-2 border-accent; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 4px; flex-shrink: 0; }
  .xp-bullet .core { @apply bg-accent; width: 8px; height: 8px; border-radius: 50%; }
  .xp-item.current .xp-bullet .core { box-shadow: 0 0 0 5px color-mix(in oklab, var(--accent) 30%, transparent); }
  .xp-meta { display: flex; align-items: baseline; gap: 12px; margin-bottom: 4px; flex-wrap: wrap; }
  .xp-period { @apply text-muted-custom; font-family: var(--font-mono); font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; }
  .xp-period .now { @apply text-accent; font-weight: 500; }
  .xp-content h4 { font-size: 24px; font-weight: 700; letter-spacing: -0.02em; margin: 4px 0 4px; }
  .xp-role { @apply text-coral; font-size: 15px; font-weight: 500; margin-bottom: 10px; }
  .xp-summary { @apply text-ink-soft; font-size: 15px; line-height: 1.65; max-width: 60ch; margin-bottom: 12px; }
  .xp-tech { @apply text-muted-custom; display: flex; flex-wrap: wrap; gap: 5px; font-family: var(--font-mono); font-size: 11px; }
  .xp-tech span { @apply border border-line; padding: 3px 8px; border-radius: 999px; }
</style>
