---
import { getLangFromUrl } from '../i18n/utils'
const lang = getLangFromUrl(Astro.url)
---

<header class="topbar">
  <div class="topbar-inner">
    <a class="brand" href="#top">
      <span class="blob"></span>
      <span>vitualizz</span>
    </a>

    <nav class="nav-links">
      <a href="#top" class="active" data-nav>Presentación</a>
      <a href="#about" data-nav>Sobre mí</a>
      <a href="#ai" data-nav>Pregúntale</a>
      <a href="#projects" data-nav>Proyectos</a>
      <a href="#xp" data-nav>Experiencia</a>
      <a href="#blog" data-nav>Blog</a>
      <a href="#contact" data-nav>Contacto</a>
    </nav>

    <div class="nav-right">
      <a class="pill" href="/cv/es.pdf">Curriculum</a>
      <a class="pill" href={lang === 'es' ? '/en' : '/es'} aria-label="Cambiar idioma">
        {lang === 'es' ? 'ESP' : 'ENG'}
        <span class="flag flag-pe" aria-hidden="true"></span>
      </a>
      <button class="theme-toggle" aria-label="Cambiar tema" id="themeToggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  .topbar {
    position: sticky; top: 0; z-index: 30;
    background: color-mix(in oklab, var(--bg) 75%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid color-mix(in oklab, var(--line) 80%, transparent);
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 72px; max-width: var(--max); margin: 0 auto; padding: 0 var(--gutter);
  }
  .brand {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--font-display); font-weight: 700; letter-spacing: -0.02em; font-size: 17px;
    color: var(--ink);
  }
  .brand .blob {
    width: 28px; height: 28px;
    background: var(--accent);
    border-radius: 56% 44% 40% 60% / 60% 50% 50% 40%;
    box-shadow: 0 0 24px color-mix(in oklab, var(--accent) 30%, transparent);
    animation: morph 9s ease-in-out infinite;
  }
  .nav-links { display: flex; gap: 36px; font-size: 15px; font-weight: 500; }
  .nav-links a { position: relative; padding: 6px 0; color: var(--ink-soft); transition: color .2s; white-space: nowrap; }
  .nav-links a:hover { color: var(--ink); }
  .nav-links a.active { color: var(--ink); }
  .nav-links a.active::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: -2px;
    height: 3px; background: var(--accent); border-radius: 999px;
  }
  .nav-right { display: flex; align-items: center; gap: 14px; }
  .pill {
    display: inline-flex; align-items: center; gap: 8px; padding: 9px 16px;
    border: 1px solid var(--line); border-radius: 999px; font-size: 14px; font-weight: 500;
    background: color-mix(in oklab, var(--bg-2) 80%, transparent);
    transition: border-color .2s, background .2s, transform .2s; color: var(--ink);
  }
  .pill:hover { border-color: var(--accent); transform: translateY(-1px); }
  .flag { width: 18px; height: 12px; border-radius: 2px; overflow: hidden; display: inline-block; }
  .flag-pe { background: linear-gradient(90deg, #D91023 33%, #fff 33% 66%, #D91023 66%); }
  .theme-toggle {
    width: 38px; height: 38px; border-radius: 50%; border: 1px solid var(--line);
    background: var(--bg-2); display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; transition: border-color .2s, transform .2s;
  }
  .theme-toggle:hover { border-color: var(--accent); transform: rotate(-15deg); }
  .theme-toggle svg { width: 18px; height: 18px; color: var(--ink-soft); }

  @media (max-width: 1080px) { .nav-links { gap: 22px; font-size: 14px; } }
  @media (max-width: 940px) { .nav-links { display: none; } }
</style>

<script>
  function initNavbar() {
    // Theme toggle
    const btn = document.getElementById('themeToggle');
    if (btn) {
      btn.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme');
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('portfolio-theme', next);
        // show/hide stars
        const stars = document.querySelectorAll('.stars, .stars2, .stars3');
        stars.forEach(s => (s as HTMLElement).style.display = next === 'dark' ? '' : 'none');
      });
    }

    // Active nav highlight on scroll
    const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav]');
    const sectionMap = Array.from(navLinks).map(a => ({
      a, target: document.querySelector(a.getAttribute('href') || '') as HTMLElement | null
    })).filter(x => x.target);

    function updateActive() {
      const y = window.scrollY + 120;
      let active = sectionMap[0];
      for (const item of sectionMap) {
        if (item.target && item.target.offsetTop <= y) active = item;
      }
      navLinks.forEach(a => a.classList.toggle('active', a === active?.a));
    }
    window.addEventListener('scroll', updateActive, { passive: true });
    updateActive();
  }
  initNavbar();
  document.addEventListener('astro:page-load', initNavbar);
</script>
