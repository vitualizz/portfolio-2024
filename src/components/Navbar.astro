---
import { getLangFromUrl } from '../i18n/utils'
import { useTranslation } from 'src/i18n/utils'
import ResumeActions from 'src/components/ResumeActions.astro'
import ThemeToggle from 'src/components/ThemeToggle.astro'
import { LANG_CODES, SECTION_IDS, withLangPath } from 'src/i18n/constants'
const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
---

<portfolio-navbar>
  <header
    class="topbar sticky top-0 z-30"
    style="background:color-mix(in oklab, var(--bg) 75%, transparent);backdrop-filter:blur(14px) saturate(140%);-webkit-backdrop-filter:blur(14px) saturate(140%);border-bottom:1px solid color-mix(in oklab, var(--line) 80%, transparent)"
  >
    <div
      class="topbar-inner mx-auto flex h-[72px] items-center justify-between px-[var(--gutter)]"
      style="max-width:var(--max)"
    >
      <a
        class="brand font-display text-ink inline-flex items-center gap-[10px] text-[17px] font-bold tracking-[-0.02em]"
        href={`/${lang}`}
      >
        <span
          class="blob bg-accent h-7 w-7"
          style="border-radius:56% 44% 40% 60% / 60% 50% 50% 40%;box-shadow:0 0 24px color-mix(in oklab, var(--accent) 30%, transparent)"
        ></span>
        <span>vitualizz</span>
      </a>

      <nav class="nav-links flex gap-8 text-[14.5px] font-medium">
        <a href={withLangPath(lang, `#${SECTION_IDS.about}`)} data-nav
          >{t('nav').about_me}</a
        >
        <a href={withLangPath(lang, `#${SECTION_IDS.projects}`)} data-nav
          >{t('nav').projects}</a
        >
        <a href={withLangPath(lang, '/blog')} data-nav-blog
          >{t('nav').blog}<span class="nav-cat" aria-hidden="true">🐾</span></a
        >
        <a href={withLangPath(lang, `#${SECTION_IDS.contact}`)} data-nav
          >{t('nav').contact_me}</a
        >
      </nav>

      <div class="nav-right flex items-center gap-[14px]">
        <ResumeActions
          lang={lang}
          variant="navbar"
          triggerId="resume-actions-navbar"
        />
        <details class="lang-menu relative">
          <summary
            class="pill border-line text-ink hover:border-accent inline-flex cursor-pointer list-none items-center gap-2 rounded-full border px-4 py-[9px] text-[14px] font-medium transition-[border-color,background,transform] duration-200 hover:-translate-y-px"
            aria-label={t('nav').switch_language}
            style="background:color-mix(in oklab, var(--bg-2) 80%, transparent)"
          >
            {lang.toUpperCase()}
          </summary>
          <div
            class="border-line bg-bg-2 absolute top-[calc(100%+8px)] right-0 z-20 min-w-[130px] rounded-[12px] border p-1"
          >
            {
              LANG_CODES.map((code) => (
                <a
                  href={withLangPath(code)}
                  class={`block rounded-[8px] px-3 py-2 text-[13px] ${code === lang ? 'text-accent' : 'text-ink-soft hover:text-ink'}`}
                  aria-label={t('nav').language_option.replace(
                    '{language}',
                    code === 'es' ? 'Español' : 'English'
                  )}
                >
                  {code === 'es' ? 'Español' : 'English'}
                </a>
              ))
            }
          </div>
        </details>
        <ThemeToggle />
      </div>
    </div>
  </header>
</portfolio-navbar>

<style>
  .blob {
    animation: morph 9s ease-in-out infinite;
  }
  .nav-links a {
    position: relative;
    padding: 6px 0;
    color: var(--ink-soft);
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav-links a:hover {
    color: var(--ink);
  }
  .nav-links a.active {
    color: var(--ink);
  }
  .nav-links a.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 3px;
    background: var(--accent);
    border-radius: 999px;
  }
  @media (max-width: 1080px) {
    .nav-links {
      gap: 22px;
      font-size: 14px;
    }
  }
  @media (max-width: 940px) {
    .nav-links {
      display: none;
    }
  }
</style>

<script>
  type NavbarItem = {
    a: HTMLAnchorElement
    target: HTMLElement | null
  }

  class PortfolioNavbarElement extends HTMLElement {
    private navLinks: HTMLAnchorElement[] = []
    private sectionMap: NavbarItem[] = []
    private onScroll = () => this.updateActive()

    connectedCallback() {
      this.navLinks = Array.from(
        this.querySelectorAll<HTMLAnchorElement>('[data-nav]')
      )

      // On blog pages, mark the blog link active and skip scroll-based tracking
      if (window.location.pathname.includes('/blog')) {
        const blogLink = this.querySelectorAll<HTMLAnchorElement>('[data-nav-blog]')[0]
        if (blogLink) {
          this.navLinks.forEach((a) => a.classList.remove('active'))
          blogLink.classList.add('active')
        }
        return
      }

      this.sectionMap = this.navLinks
        .map((a) => ({
          a,
          target: document.querySelector(a.hash || '') as HTMLElement | null
        }))
        .filter((item): item is NavbarItem => Boolean(item.target))

      window.addEventListener('scroll', this.onScroll, { passive: true })
      this.updateActive()
    }

    disconnectedCallback() {
      window.removeEventListener('scroll', this.onScroll)
      this.navLinks = []
      this.sectionMap = []
    }

    private updateActive() {
      if (!this.sectionMap.length) return

      const y = window.scrollY + 120
      let active = this.sectionMap[0]

      for (const item of this.sectionMap) {
        if (item.target && item.target.offsetTop <= y) active = item
      }

      this.navLinks.forEach((a) =>
        a.classList.toggle('active', a === active?.a)
      )
    }
  }

  if (!customElements.get('portfolio-navbar')) {
    customElements.define('portfolio-navbar', PortfolioNavbarElement)
  }
</script>
