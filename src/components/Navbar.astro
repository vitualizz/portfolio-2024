---
import { getLangFromUrl } from '../i18n/utils'
import { useTranslation } from 'src/i18n/utils'
import ResumeActions from 'src/components/ResumeActions.astro'
import ThemeToggle from 'src/components/ThemeToggle.astro'
import { LANG_CODES, SECTION_IDS, withLangPath } from 'src/i18n/constants'
const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
---

<header
  class="topbar sticky top-0 z-30"
  style="background:color-mix(in oklab, var(--bg) 75%, transparent);backdrop-filter:blur(14px) saturate(140%);-webkit-backdrop-filter:blur(14px) saturate(140%);border-bottom:1px solid color-mix(in oklab, var(--line) 80%, transparent)"
>
  <div
    class="topbar-inner mx-auto flex h-[72px] items-center justify-between px-[var(--gutter)]"
    style="max-width:var(--max)"
  >
    <a
      class="brand font-display text-ink inline-flex items-center gap-[10px] text-[17px] font-bold tracking-[-0.02em]"
      href={`/${lang}`}
    >
      <span
        class="blob bg-accent h-7 w-7"
        style="border-radius:56% 44% 40% 60% / 60% 50% 50% 40%;box-shadow:0 0 24px color-mix(in oklab, var(--accent) 30%, transparent)"
      ></span>
      <span>vitualizz</span>
    </a>

    <nav class="nav-links flex gap-9 text-[15px] font-medium">
      <a
        href={withLangPath(lang, `#${SECTION_IDS.top}`)}
        class="active"
        data-nav>{t('nav').presentation}</a
      >
      <a href={withLangPath(lang, `#${SECTION_IDS.about}`)} data-nav
        >{t('nav').about_me}</a
      >
      <a href={withLangPath(lang, `#${SECTION_IDS.ai}`)} data-nav
        >{t('nav').ask_ai}</a
      >
      <a href={withLangPath(lang, `#${SECTION_IDS.projects}`)} data-nav
        >{t('nav').projects}</a
      >
      <a href={withLangPath(lang, `#${SECTION_IDS.xp}`)} data-nav
        >{t('nav').work_experience}</a
      >
      <a href={withLangPath(lang, `#${SECTION_IDS.blog}`)} data-nav
        >{t('nav').blog}</a
      >
      <a href={withLangPath(lang, `#${SECTION_IDS.contact}`)} data-nav
        >{t('nav').contact_me}</a
      >
    </nav>

    <div class="nav-right flex items-center gap-[14px]">
      <ResumeActions
        lang={lang}
        variant="navbar"
        triggerId="resume-actions-navbar"
      />
      <details class="lang-menu relative">
        <summary
          class="pill border-line text-ink inline-flex cursor-pointer list-none items-center gap-2 rounded-full border px-4 py-[9px] text-[14px] font-medium"
          aria-label={t('nav').switch_language}
          style="background:color-mix(in oklab, var(--bg-2) 80%, transparent)"
        >
          {lang.toUpperCase()}
        </summary>
        <div
          class="border-line bg-bg-2 absolute top-[calc(100%+8px)] right-0 z-20 min-w-[130px] rounded-[12px] border p-1"
        >
          {
            LANG_CODES.map((code) => (
              <a
                href={withLangPath(code)}
                class={`block rounded-[8px] px-3 py-2 text-[13px] ${code === lang ? 'text-accent' : 'text-ink-soft hover:text-ink'}`}
                aria-label={t('nav').language_option.replace(
                  '{language}',
                  code === 'es' ? 'Español' : 'English'
                )}
              >
                {code === 'es' ? 'Español' : 'English'}
              </a>
            ))
          }
        </div>
      </details>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .blob {
    animation: morph 9s ease-in-out infinite;
  }
  .nav-links a {
    position: relative;
    padding: 6px 0;
    color: var(--ink-soft);
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav-links a:hover {
    color: var(--ink);
  }
  .nav-links a.active {
    color: var(--ink);
  }
  .nav-links a.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 3px;
    background: var(--accent);
    border-radius: 999px;
  }
  .pill {
    transition:
      border-color 0.2s,
      background 0.2s,
      transform 0.2s;
  }
  .pill:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .flag-pe {
    background: linear-gradient(90deg, #d91023 33%, #fff 33% 66%, #d91023 66%);
  }
  @media (max-width: 1080px) {
    .nav-links {
      gap: 22px;
      font-size: 14px;
    }
  }
  @media (max-width: 940px) {
    .nav-links {
      display: none;
    }
  }
</style>

<script>
  const NAVBAR_INIT_FLAG = 'navbarPageLoadBound'

  type NavbarItem = {
    a: HTMLAnchorElement
    target: HTMLElement | null
  }

  type NavbarState = {
    navLinks: HTMLAnchorElement[]
    sectionMap: NavbarItem[]
    updateActive: () => void
  }

  declare global {
    interface Window {
      __navbarScrollBound?: boolean
      __navbarState?: NavbarState
    }
  }

  function initNavbar() {
    const navLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('[data-nav]')
    )
    const sectionMap = navLinks
      .map((a) => ({
        a,
        target: document.querySelector(a.hash || '') as HTMLElement | null
      }))
      .filter((x) => x.target)

    const state = window.__navbarState || {
      navLinks: [],
      sectionMap: [],
      updateActive: () => {}
    }

    state.navLinks = navLinks
    state.sectionMap = sectionMap

    state.updateActive = function updateActive() {
      const y = window.scrollY + 120
      let active = state.sectionMap[0]
      for (const item of state.sectionMap) {
        if (item.target && item.target.offsetTop <= y) active = item
      }
      state.navLinks.forEach((a) => a.classList.toggle('active', a === active?.a))
    }

    window.__navbarState = state

    if (!window.__navbarScrollBound) {
      window.addEventListener(
        'scroll',
        () => {
          window.__navbarState?.updateActive()
        },
        { passive: true }
      )
      window.__navbarScrollBound = true
    }

    state.updateActive()
  }

  initNavbar()

  if (document.documentElement.dataset[NAVBAR_INIT_FLAG] !== 'true') {
    document.addEventListener('astro:page-load', initNavbar)
    document.documentElement.dataset[NAVBAR_INIT_FLAG] = 'true'
  }
</script>
