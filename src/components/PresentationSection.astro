---
import { getLangFromUrl, useTranslation } from '../i18n/utils.ts'
import PresentationActions from './PresentationActions.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
const tp = t('presentation')

// Generate star positions at build time
const stars = Array.from({ length: 90 }, (_, i) => ({
  x: ((i * 137.5) % 100).toFixed(2),
  y: ((i * 97.3 + 11) % 100).toFixed(2),
  size: i % 7 === 0 ? 2 : 1,
  opacity: (0.2 + (i % 5) * 0.15).toFixed(2),
  delay: ((i % 4) * 0.8).toFixed(1),
}))
---

<section
  id="presentation"
  data-section="presentation"
  class="relative min-h-screen flex items-center overflow-hidden bg-[#0D0D0F]"
>
  <!-- Star field -->
  <div aria-hidden="true" class="stars-layer pointer-events-none absolute inset-0">
    {stars.map(s => (
      <span
        class="star-dot"
        style={`left:${s.x}%;top:${s.y}%;width:${s.size}px;height:${s.size}px;opacity:${s.opacity};animation-delay:${s.delay}s`}
      />
    ))}
  </div>

  <!-- Decorative sparkles -->
  <span aria-hidden="true" class="sparkle sparkle-pink absolute right-[36%] top-[28%] text-pink-400">✦</span>
  <span aria-hidden="true" class="sparkle sparkle-yellow absolute right-[22%] bottom-[30%] text-accent">✦</span>
  <span aria-hidden="true" class="sparkle sparkle-sm absolute left-[48%] top-[55%] text-accent/60">✦</span>

  <!-- Content -->
  <div class="hero-content w-full flex-col gap-12 px-6 py-24 lg:flex-row-reverse lg:gap-16 lg:px-16">

    <!-- Orb + image -->
    <div class="orb-wrap hero-img relative flex-shrink-0 w-64 sm:w-80 lg:w-[44%]">
      <!-- Outer glow -->
      <div class="absolute inset-[-10%] rounded-full bg-accent/10 blur-3xl"></div>
      <!-- Middle ring -->
      <div class="absolute inset-[6%] rounded-full bg-accent/20 blur-xl"></div>
      <!-- Orb surface -->
      <div class="orb relative rounded-full overflow-hidden flex items-end justify-center"
           style="background: radial-gradient(ellipse at 40% 35%, #f5e070 0%, #f3d463 35%, #c9960a 70%, #3a2500 100%);">
        <img
          src="/img/Logo2.webp"
          alt="Lee Palacios"
          class="relative w-[90%] z-10"
          loading="eager"
          decoding="async"
        />
      </div>
      <!-- vitualizz badge -->
      <div class="absolute right-4 top-6 z-20 rounded-full bg-black/90 px-4 py-1.5 text-sm font-medium text-white border border-white/10 shadow-lg">
        vitualizz
      </div>
    </div>

    <!-- Text -->
    <div class="hero-text m-auto w-[90%] lg:w-full lg:max-w-xl">
      <p class="mb-3 text-base text-white/55 lg:text-lg">{tp.hi}</p>

      <h1 class="mb-4 font-display font-bold leading-[0.95] tracking-tight">
        <span class="block text-4xl text-white sm:text-5xl lg:text-6xl xl:text-7xl">
          {lang === 'es' ? 'Soy' : "I'm"}
        </span>
        <span class="name-line block text-4xl text-accent sm:text-5xl lg:text-6xl xl:text-7xl">
          Lee Palacios
        </span>
      </h1>

      <p class="mb-4 text-lg text-white lg:text-xl">{tp.profession}</p>
      <p class="mb-8 text-sm leading-relaxed text-white/55 lg:text-base" set:html={tp.description} />
      <PresentationActions />
    </div>
  </div>
</section>

<style>
  /* Stars */
  .star-dot {
    position: absolute;
    border-radius: 9999px;
    background: white;
    animation: twinkle 3s ease-in-out infinite;
  }
  @keyframes twinkle {
    0%, 100% { opacity: var(--tw-opacity, 0.3); }
    50% { opacity: 1; }
  }

  /* Sparkles */
  .sparkle { font-size: 1.25rem; animation: sparkle-pulse 2.5s ease-in-out infinite; }
  .sparkle-pink { animation-delay: 0.3s; }
  .sparkle-yellow { animation-delay: 1.1s; font-size: 0.9rem; }
  .sparkle-sm { font-size: 0.75rem; animation-delay: 1.8s; }
  @keyframes sparkle-pulse {
    0%, 100% { opacity: 0.4; transform: scale(1) rotate(0deg); }
    50% { opacity: 1; transform: scale(1.3) rotate(20deg); }
  }

  /* Orb */
  .orb { aspect-ratio: 1; }

  /* Name underline */
  .name-line {
    position: relative;
    display: inline-block;
  }
  .name-line::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0;
    right: 0;
    height: 6px;
    background: color-mix(in oklch, #f3d463 40%, transparent);
    border-radius: 3px;
  }

  /* Load animations */
  .hero-img {
    animation: hero-in-right 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.15s;
  }
  .hero-text {
    animation: hero-in-left 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 0.05s;
  }
  @keyframes hero-in-right {
    from { opacity: 0; transform: translateX(32px); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes hero-in-left {
    from { opacity: 0; transform: translateX(-24px); }
    to   { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .star-dot, .sparkle { animation: none; }
    .hero-img, .hero-text { animation: none; }
  }
</style>
