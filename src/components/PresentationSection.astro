---
---

<section class="hero" id="top">
  <div class="hero-spotlight" id="heroSpotlight"></div>
  <div class="wrap">
    <div class="hero-grid">

      <!-- Left: text -->
      <div>
        <div class="hero-greet">Hola, <span class="rocket">🚀</span></div>

        <div class="hero-badges">
          <span class="hb hb-ai"><span class="hb-dot"></span>AI Builder</span>
          <span class="hb">Backend at heart</span>
          <span class="hb hb-mute">@ Patrimore</span>
        </div>

        <h1>
          Soy <span class="name">Lee Palacios</span>
        </h1>

        <p class="profession">
          <span class="profession-arrow">›</span>
          <span class="typewriter" id="typewriter"
            data-words="Senior Fullstack Engineer|Backend by night, Frontend by day|AI agents · LLM orchestration|Ruby, Python &amp; Postgres lover|Cat dad · 3 gatos">Senior Fullstack Engineer</span><span class="caret">│</span>
        </p>

        <p class="description">
          <span class="y">+7 años</span> diseñando y construyendo producto en startups latinoamericanas. <b>Vivo en el backend</b> — SQL afinado, arquitecturas que escalan, modelos de datos honestos — y construyo con IA cuando el problema lo pide. Hoy en <b>Patrimore</b>; siempre en GitHub.
        </p>

        <div class="hero-actions">
          <a class="icon-btn" href="https://github.com/vitualizz" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-2.1c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.68 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.18-1.49 3.14-1.18 3.14-1.18.63 1.59.23 2.76.12 3.05.74.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.38-5.25 5.67.41.36.78 1.05.78 2.12v3.14c0 .31.21.66.79.55A11.51 11.51 0 0 0 23.5 12c0-6.35-5.15-11.5-11.5-11.5z"/></svg>
          </a>
          <a class="icon-btn linkedin" href="https://linkedin.com/in/vitualizz" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z"/></svg>
          </a>
          <button class="icon-btn" data-open-modal="contact" aria-label="Enviar mensaje">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="3,7 12,13 21,7"/></svg>
          </button>
          <a class="icon-btn" href="/cv/es.pdf" aria-label="Currículum">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/></svg>
          </a>
          <a class="icon-btn primary-cta" href="#ai">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 L13.5 8.5 L20 10 L13.5 11.5 L12 18 L10.5 11.5 L4 10 L10.5 8.5 Z"/></svg>
            <span class="cta-label">Pregunta a mi IA</span>
          </a>
        </div>
      </div>

      <!-- Right: character image -->
      <div class="hero-figure">
        <span class="blob-tag">vitualizz online</span>
        <img class="hero-character" src="/img/Logo2.webp" alt="Lee Palacios — illustrated character with cats" loading="eager" decoding="async" />
        <span class="blob-spark s1">✦</span>
        <span class="blob-spark s2">✧</span>
        <span class="blob-spark s3">✦</span>
        <span class="blob-spark s4">✨</span>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-spotlight {
    position: absolute; inset: 0; pointer-events: none; z-index: 0;
    background: radial-gradient(420px circle at var(--mx, 50%) var(--my, 50%), color-mix(in oklab, var(--accent) 14%, transparent), transparent 60%);
    opacity: 0; transition: opacity .4s ease;
  }
  .hero { min-height: calc(100vh - 72px); display: flex; align-items: center; padding: clamp(40px,6vw,80px) 0 clamp(60px,10vw,120px); position: relative; }
  .hero > .wrap { position: relative; z-index: 1; width: 100%; }
  .hero-grid { display: grid; grid-template-columns: 1.15fr 1fr; gap: clamp(32px,5vw,80px); align-items: center; width: 100%; }

  .hero-greet { font-family: var(--font-sans); font-size: clamp(20px,2vw,26px); font-weight: 500; color: var(--ink-soft); margin-bottom: 16px; display: inline-flex; align-items: center; gap: 10px; }
  .rocket { display: inline-block; font-size: 1.1em; animation: rocket 2.4s ease-in-out infinite; }

  .hero-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
  .hb { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 11.5px; padding: 6px 12px; border-radius: 999px; background: var(--bg-2); border: 1px solid var(--line); color: var(--ink-soft); letter-spacing: 0.02em; transition: border-color .2s, transform .2s; }
  .hb:hover { transform: translateY(-2px); border-color: var(--accent); }
  .hb.hb-ai { background: linear-gradient(110deg, color-mix(in oklab, var(--coral) 18%, var(--bg-2)), var(--bg-2)); border-color: color-mix(in oklab, var(--coral) 45%, var(--line)); color: var(--ink); font-weight: 600; }
  .hb.hb-ai .hb-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--coral); box-shadow: 0 0 0 4px color-mix(in oklab, var(--coral) 25%, transparent); animation: pulse 1.8s ease-in-out infinite; }
  .hb.hb-mute { color: var(--muted); }

  .hero h1 { font-size: clamp(40px,5.6vw,84px); font-weight: 800; letter-spacing: -0.035em; line-height: 1.08; margin-bottom: 24px; }
  .hero h1 .name { color: var(--accent); position: relative; white-space: nowrap; }

  .profession { font-size: clamp(18px,1.6vw,22px); color: var(--ink-soft); margin-bottom: 18px; font-weight: 500; display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
  .typewriter { color: var(--coral); font-weight: 600; font-family: var(--font-mono); font-size: 0.92em; letter-spacing: -0.005em; }
  .profession-arrow { color: var(--accent); font-family: var(--font-mono); font-weight: 700; }
  .caret { display: inline-block; color: var(--accent); font-weight: 400; margin-left: -4px; animation: blink 1.05s steps(2) infinite; font-family: var(--font-mono); }

  .description { font-size: clamp(15px,1.2vw,17px); color: var(--muted); max-width: 48ch; line-height: 1.7; margin-bottom: 36px; }
  .description b { color: var(--ink); font-weight: 500; }

  .hero-actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .icon-btn {
    width: 48px; height: 48px; border-radius: 14px; background: var(--bg-2); border: 1px solid var(--line);
    display: inline-flex; align-items: center; justify-content: center;
    transition: transform .2s, background .2s, border-color .2s, color .2s; color: var(--ink);
    cursor: pointer;
  }
  .icon-btn:hover { background: var(--accent); color: #0B0C10; border-color: var(--accent); transform: translateY(-2px); }
  .icon-btn.primary-cta { width: auto; padding: 0 18px; gap: 8px; background: var(--accent); color: #0B0C10; border-color: var(--accent); font-size: 14px; font-weight: 600; font-family: var(--font-sans); letter-spacing: -0.005em; }
  .icon-btn.primary-cta:hover { background: var(--coral); color: var(--bg); border-color: var(--coral); }
  .icon-btn.primary-cta svg { width: 18px; height: 18px; }
  .icon-btn.linkedin { background: #0A66C2; color: #fff; border-color: transparent; }
  .icon-btn.linkedin:hover { background: var(--accent); color: #0B0C10; }
  .icon-btn svg { width: 22px; height: 22px; }
  @media (max-width: 540px) { .icon-btn.primary-cta .cta-label { display: none; } .icon-btn.primary-cta { width: 48px; padding: 0; } }

  /* Character */
  .hero-figure { position: relative; aspect-ratio: 1/1; max-width: 540px; width: 100%; margin-left: auto; }
  .hero-figure::before {
    content: ""; position: absolute; inset: 8% 4% 4% 4%;
    background: radial-gradient(circle at 50% 55%, color-mix(in oklab, var(--accent) 22%, transparent) 0%, transparent 65%);
    filter: blur(20px); z-index: 0; animation: glowPulse 6s ease-in-out infinite;
  }
  .hero-character { position: relative; width: 100%; height: 100%; object-fit: contain; object-position: center bottom; z-index: 1; filter: drop-shadow(0 30px 40px rgba(0,0,0,.45)); animation: floatY 8s ease-in-out infinite; }

  .blob-tag {
    position: absolute; top: 14%; right: 8%; transform: rotate(8deg);
    background: var(--bg); color: var(--ink); border: 1px solid var(--line);
    padding: 6px 16px; border-radius: 999px; font-family: var(--font-mono); font-size: 12px;
    z-index: 2; box-shadow: 0 8px 20px rgba(0,0,0,.4); animation: tagBob 5s ease-in-out infinite;
  }
  .blob-tag::before { content: "•"; color: var(--mint); margin-right: 6px; animation: pulse 2s ease-in-out infinite; }

  .blob-spark { position: absolute; font-size: 26px; z-index: 2; animation: float 4s ease-in-out infinite; }
  .blob-spark.s1 { top: 6%; right: 2%; color: var(--coral); animation-delay: .2s; }
  .blob-spark.s2 { bottom: 18%; left: -2%; color: var(--mint); animation-delay: 1.4s; font-size: 22px; }
  .blob-spark.s3 { top: 36%; right: -4%; color: var(--accent); animation-delay: 2.6s; }
  .blob-spark.s4 { bottom: 6%; right: 18%; color: var(--accent); animation-delay: 3.2s; font-size: 18px; }

  @media (max-width: 820px) {
    .hero-grid { grid-template-columns: 1fr; gap: 48px; }
    .hero-figure { max-width: 340px; margin: 0 auto; order: -1; }
    .hero { min-height: auto; padding-top: 32px; }
  }
</style>

<script>
  function initHero() {
    // Typewriter
    const el = document.getElementById('typewriter');
    if (el) {
      const words = (el.dataset.words || '').split('|').filter(Boolean);
      let w = 0, c = 0, deleting = false;
      function tick() {
        const word = words[w];
        if (!deleting) {
          c++; el.textContent = word.slice(0, c);
          if (c >= word.length) { deleting = true; setTimeout(tick, 1600); return; }
        } else {
          c--; el.textContent = word.slice(0, c);
          if (c <= 0) { deleting = false; w = (w + 1) % words.length; setTimeout(tick, 220); return; }
        }
        setTimeout(tick, deleting ? 28 : 60 + Math.random() * 40);
      }
      setTimeout(tick, 900);
    }

    // Cursor spotlight
    const hero = document.querySelector('.hero') as HTMLElement | null;
    const spot = document.getElementById('heroSpotlight');
    if (hero && spot && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      hero.addEventListener('pointermove', (e: PointerEvent) => {
        const r = hero.getBoundingClientRect();
        spot.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
        spot.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
        spot.style.opacity = '1';
      });
      hero.addEventListener('pointerleave', () => { spot.style.opacity = '0'; });
    }

    // Magnetic icon buttons
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && !window.matchMedia('(hover: none)').matches) {
      document.querySelectorAll<HTMLElement>('.icon-btn').forEach(btn => {
        btn.addEventListener('pointermove', (e: PointerEvent) => {
          const r = btn.getBoundingClientRect();
          const x = (e.clientX - r.left - r.width / 2) * 0.35;
          const y = (e.clientY - r.top - r.height / 2) * 0.35;
          btn.style.transform = `translate(${x.toFixed(1)}px,${y.toFixed(1)}px)`;
        });
        btn.addEventListener('pointerleave', () => { btn.style.transform = ''; });
      });
    }
  }
  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>
