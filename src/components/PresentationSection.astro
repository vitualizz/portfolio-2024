---
import { getLangFromUrl, useTranslation } from '../i18n/utils.ts'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
const tp = t('presentation')
---

<section
  id="presentation"
  data-section="presentation"
  class="relative min-h-screen flex items-end pb-24 px-6 lg:px-16 overflow-hidden"
>
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#0A0B0D] via-[#111318] to-[#0A0B0D] -z-10"></div>
  <!-- Accent blobs -->
  <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
  <div class="absolute bottom-1/4 left-1/3 w-64 h-64 bg-accent/5 rounded-full blur-2xl -z-10 pointer-events-none"></div>

  <div class="w-full max-w-6xl mx-auto">
    <!-- Role badge -->
    <div class="anim-fade-in mb-8">
      <span class="inline-flex items-center gap-2 text-sm font-medium text-accent border border-accent/30 rounded-full px-4 py-1.5 bg-accent/5">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        Software Engineer
      </span>
    </div>

    <!-- Main heading -->
    <h1 class="anim-fade-up font-display text-6xl md:text-8xl lg:text-[10rem] font-bold leading-[0.9] tracking-tight text-white mb-8">
      Lee<br />
      <span class="text-accent">Palacios</span><span class="text-accent">.</span>
    </h1>

    <!-- Tagline -->
    <p
      class="anim-fade-up text-lg md:text-xl text-white/60 max-w-xl mb-12 leading-relaxed"
      style="animation-delay: 0.1s"
    >
      {tp.tagline}
    </p>

    <!-- CTAs + socials -->
    <div
      class="anim-fade-up flex flex-wrap items-center gap-4"
      style="animation-delay: 0.2s"
    >
      <a
        href={`/${lang}/#projects`}
        class="inline-flex items-center gap-2 bg-accent text-[#0A0B0D] font-semibold px-6 py-3 rounded-full hover:bg-accent/90 transition-colors"
      >
        {tp.cta_primary}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
      <a
        href={`/${lang}/#contact_me`}
        class="inline-flex items-center gap-2 border border-white/20 text-white px-6 py-3 rounded-full hover:border-white/40 hover:bg-white/5 transition-colors"
      >
        {tp.cta_secondary}
      </a>

      <!-- Divider -->
      <span class="hidden md:block w-px h-8 bg-white/20 mx-2"></span>

      <!-- Social links -->
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/vitualizz"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/60 hover:text-white hover:border-white/40 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/vitualizz"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/60 hover:text-white hover:border-white/40 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 right-8 md:right-16 flex flex-col items-center gap-2 text-white/30">
    <span class="text-xs tracking-widest uppercase" style="writing-mode: vertical-rl">Scroll</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </div>
</section>
