---
import { getLangFromUrl, useTranslation } from '../i18n/utils.ts'
import PresentationActions from './PresentationActions.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
const tp = t('presentation')
---

<section
  id="presentation"
  data-section="presentation"
  class="hero min-h-screen bg-cover bg-center"
  style='
    background-image: url("/img/HeroBg.webp");
    mask-image: linear-gradient(to bottom, black 78%, transparent);
  '
>
  <div class="hero-overlay bg-black/55"></div>

  <div class="hero-content flex-col lg:flex-row-reverse">
    <!-- Logo / avatar -->
    <img
      src="/img/Logo2.webp"
      alt="Lee Palacios"
      class="hero-img mb-8 w-80 drop-shadow-[0_0_48px_rgba(243,212,99,0.2)] lg:mb-0 lg:w-[45%]"
      loading="eager"
      decoding="async"
    />

    <!-- Text content -->
    <div class="hero-text m-auto w-[85%] lg:w-full">
      <p class="mb-1 text-xl font-medium text-white/75 lg:text-2xl">
        {tp.hi}
      </p>
      <h1
        class="mb-3 font-display text-4xl font-bold leading-tight text-white lg:text-5xl xl:text-6xl"
        set:html={tp.i_am}
      />
      <p class="mb-3 text-lg text-white/80 lg:text-xl">{tp.profession}</p>
      <p
        class="mb-8 text-sm leading-relaxed text-white/55 lg:text-base"
        set:html={tp.description}
      />
      <PresentationActions />
    </div>
  </div>
</section>

<style>
  .hero-img {
    animation: hero-fade-left 0.7s ease both;
    animation-delay: 0.2s;
  }
  .hero-text {
    animation: hero-fade-right 0.7s ease both;
    animation-delay: 0.1s;
  }

  @keyframes hero-fade-left {
    from { opacity: 0; transform: translateX(24px); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes hero-fade-right {
    from { opacity: 0; transform: translateX(-24px); }
    to   { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-img,
    .hero-text { animation: none; }
  }
</style>
