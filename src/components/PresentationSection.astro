---
import { getLangFromUrl, useTranslation } from '../i18n/utils.ts'
import PresentationActions from './PresentationActions.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)
const tp = t('presentation')
---

<section
  id="presentation"
  data-section="presentation"
  class="hero min-h-screen bg-cover bg-center"
  style='
    background-image: url("/img/HeroBg.webp");
    mask-image: linear-gradient(to bottom, black 78%, transparent);
  '
>
  <div class="hero-overlay bg-black/55"></div>

  <div class="hero-content w-full max-w-6xl flex-col gap-8 px-6 py-24 lg:flex-row-reverse lg:gap-20 lg:items-center lg:px-8">

    <!-- Logo / avatar -->
    <div class="anim-fade-in w-56 flex-shrink-0 sm:w-72 lg:w-5/12">
      <img
        src="/img/Logo2.webp"
        alt="Lee Palacios"
        class="w-full drop-shadow-[0_0_48px_rgba(243,212,99,0.18)]"
        loading="eager"
        decoding="async"
      />
    </div>

    <!-- Text content -->
    <div class="anim-slide-right flex-1">
      <p class="mb-1 text-xl font-medium text-white/75 lg:text-2xl">
        {tp.hi}
      </p>
      <h1
        class="mb-3 font-display text-4xl font-bold leading-tight text-white lg:text-5xl xl:text-6xl"
        set:html={tp.i_am}
      />
      <p class="mb-3 text-lg text-white/70 lg:text-xl">{tp.profession}</p>
      <p
        class="mb-8 max-w-md text-sm leading-relaxed text-white/50 lg:text-base"
        set:html={tp.description}
      />
      <PresentationActions />
    </div>
  </div>
</section>
