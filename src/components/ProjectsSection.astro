---
import projects from 'src/data/projects.json'
import Icon from 'src/components/Icon.astro'
import { getLangFromUrl } from 'src/i18n/utils'
import type { IconType } from 'src/types/Icons.types.ts'

const lang = getLangFromUrl(Astro.url)

const VALID_ICONS = new Set<string>([
  'javascript','ruby','typescript','python','sql','rails','react','tailwind',
  'astro','vue','node','postgres','aws','selenium','git','docker',
  'elasticsearch','lambda','dynamodb','redux','gpt'
])
---

<section class="s" id="projects">
  <div class="wrap">
    <div class="s-head reveal">
      <span class="s-eyebrow">// 03 · Proyectos</span>
      <h2 class="s-title">Selected <span class="y">work</span></h2>
      <p class="s-sub">Trabajo enviado a producción. Click para ver demo o código.</p>
    </div>

    <div class="projects">
      {projects.map(project => {
        const href = project.demo ?? project.githubUrl ?? '#'
        const description = lang === 'es' ? project.description_es : project.description_en
        return (
          <a class="project reveal" href={href} target="_blank" rel="noopener noreferrer">
            <div class="project-img">
              <img src={`/img/projects/${project.image}.webp`} alt={project.title} loading="lazy" />
            </div>
            <div class="project-body">
              <div class="project-head"><h3>{project.title}</h3></div>
              <p>{description}</p>
              <div class="project-foot">
                <div class="project-stack">
                  {project.stack.map(s => (
                    VALID_ICONS.has(s.icon)
                      ? <span title={s.tooltip}><Icon name={s.icon as IconType} /></span>
                      : <span class="stack-text">{s.tooltip}</span>
                  ))}
                </div>
                <span class="project-link">Ver sitio <span class="arrow">↗</span></span>
              </div>
            </div>
          </a>
        )
      })}
    </div>
  </div>
</section>

<style>
  .projects { display: grid; grid-template-columns: repeat(2,1fr); gap: 24px; }
  .project { @apply bg-bg-2 border border-line text-ink; border-radius: 20px; overflow: hidden; display: flex; flex-direction: column; transition: transform .3s ease, border-color .3s ease, box-shadow .3s ease; transform-style: preserve-3d; will-change: transform; }
  .project:hover { transform: translateY(-6px); border-color: color-mix(in oklab, var(--accent) 40%, var(--line)); box-shadow: 0 24px 50px rgba(0,0,0,.3); }
  .project-img { @apply bg-bg-3; position: relative; aspect-ratio: 16/10; overflow: hidden; }
  .project-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; }
  .project:hover .project-img img { transform: scale(1.04); }
  .project-img::after { content: ""; position: absolute; inset: 0; background: linear-gradient(to top, rgba(11,12,16,.55), transparent 40%); }
  .project-body { padding: 24px 24px 26px; display: flex; flex-direction: column; flex: 1; }
  .project-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 8px; }
  .project h3 { font-size: 22px; font-weight: 700; letter-spacing: -0.02em; }
  .project p { @apply text-muted-custom; font-size: 14.5px; line-height: 1.6; margin: 0 0 18px; flex: 1; }
  .project-foot { display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .project-stack { display: flex; flex-wrap: wrap; gap: 5px; align-items: center; }
  .project-stack span { display: inline-flex; align-items: center; }
  .project-stack .stack-text { @apply text-ink-soft border border-line; font-family: var(--font-mono); font-size: 10.5px; padding: 3px 8px; background: color-mix(in oklab, var(--bg) 70%, transparent); border-radius: 999px; }
  .project-link { @apply text-accent; display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 12px; white-space: nowrap; }
  .project-link .arrow { transition: transform .2s; }
  .project:hover .project-link .arrow { transform: translate(3px,-3px); }
  @media (max-width: 720px) { .projects { grid-template-columns: 1fr; } }
</style>

<script>
  function initProjects() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(hover: none)').matches) return;
    document.querySelectorAll<HTMLElement>('.project').forEach(card => {
      card.addEventListener('pointermove', (e: PointerEvent) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        card.style.transform = `translateY(-6px) rotateX(${(-y*4).toFixed(2)}deg) rotateY(${(x*6).toFixed(2)}deg)`;
      });
      card.addEventListener('pointerleave', () => { card.style.transform = ''; });
    });
  }
  initProjects();
  document.addEventListener('astro:page-load', initProjects);
</script>
