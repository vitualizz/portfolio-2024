---
import { useTranslation } from 'src/i18n/utils'
import { safeI18nHtml } from 'src/components/shared/i18nRichText'

interface Props {
  lang: 'es' | 'en'
}
const { lang } = Astro.props
const t = useTranslation(lang)
const aiT = t('ai')
---

<section class="s" id="ai" data-ai-root>
  <div class="wrap">
    <div class="s-head reveal">
      <span class="s-eyebrow">{t('home').ai_eyebrow}</span>
      <h2 class="s-title" set:html={safeI18nHtml(t('home').ai_title)} />
      <p class="s-sub">
        {t('home').ai_subtitle}
      </p>
    </div>

    <div
      class="ai-shell reveal border-line relative mx-auto max-w-[900px] overflow-hidden rounded-[18px] border bg-[linear-gradient(180deg,var(--bg-2)_0%,color-mix(in_oklab,var(--bg-2)_80%,var(--bg))_100%)] shadow-[0_24px_60px_rgba(0,0,0,.35)]"
    >
      <div
        class="absolute inset-x-0 top-0 h-[2px] bg-[linear-gradient(90deg,transparent,var(--accent),var(--coral),var(--mint),transparent)] opacity-[0.8]"
        aria-hidden="true"
      >
      </div>
      <div
        class="ai-header border-line flex flex-wrap items-center justify-between gap-3 border-b bg-[color:color-mix(in_oklab,var(--bg)_60%,transparent)] px-[18px] py-[14px]"
      >
        <div
          class="ai-status flex items-center gap-[10px] font-mono text-[12px]"
        >
          <span
            class="ai-dot bg-mint h-2 w-2 rounded-full shadow-[0_0_0_4px_color-mix(in_oklab,var(--mint)_25%,transparent)]"
          ></span>
          <span class="text-ink ai-label">Lee IA · v1</span>
        </div>
        <div class="flex flex-wrap gap-1">
          <button
            class="ai-tab border-line text-ink-soft cursor-pointer rounded-[8px] border bg-transparent px-[10px] py-[5px] font-mono text-[11px] transition-all duration-200"
            data-suggest={aiT.tabs.backend}>{aiT.tab_labels.backend}</button
          >
          <button
            class="ai-tab border-line text-ink-soft cursor-pointer rounded-[8px] border bg-transparent px-[10px] py-[5px] font-mono text-[11px] transition-all duration-200"
            data-suggest={aiT.tabs.ai_builder}
            >{aiT.tab_labels.ai_builder}</button
          >
          <button
            class="ai-tab border-line text-ink-soft cursor-pointer rounded-[8px] border bg-transparent px-[10px] py-[5px] font-mono text-[11px] transition-all duration-200"
            data-suggest={aiT.tabs.postgres}>{aiT.tab_labels.postgres}</button
          >
          <button
            class="ai-tab border-line text-ink-soft cursor-pointer rounded-[8px] border bg-transparent px-[10px] py-[5px] font-mono text-[11px] transition-all duration-200"
            data-suggest={aiT.tabs.culture}>{aiT.tab_labels.culture}</button
          >
        </div>
      </div>

      <div
        class="ai-conv flex max-h-[420px] flex-col gap-[18px] overflow-y-auto scroll-smooth px-[22px] pt-6 pb-3"
        id="aiConv"
        aria-live="polite"
        aria-atomic="false"
      >
        <div
          class="ai-invite flex flex-col items-center justify-center gap-2 py-8 text-center"
          id="aiInvite"
        >
          <p
            class="text-ink text-[15px] leading-[1.6]"
            set:html={safeI18nHtml(aiT.greeting)}
          />
          <p class="font-mono text-[11.5px] text-[color:var(--muted)]">
            {aiT.hint}
          </p>
        </div>
      </div>

      <form
        class="ai-form border-line flex items-center border-t bg-[color:color-mix(in_oklab,var(--bg)_80%,transparent)] px-[14px] py-3"
        id="aiForm"
        data-ai={JSON.stringify(aiT)}
      >
        <span class="text-accent px-[10px] font-mono text-[18px] font-bold"
          >›</span
        >
        <input
          id="aiInput"
          type="text"
          placeholder={aiT.input_placeholder}
          autocomplete="off"
          maxlength="280"
          class="text-ink placeholder:text-muted-custom flex-1 border-none bg-transparent px-1 py-[10px] font-sans text-[15px] outline-none"
        />
        <button
          class="ai-send bg-accent hover:bg-coral disabled:bg-surface-2 disabled:text-muted-custom flex h-[38px] w-[38px] cursor-pointer items-center justify-center rounded-[10px] border-none text-[#0B0C10] transition-[transform,background] duration-200 hover:translate-x-[2px] hover:text-white disabled:translate-x-0 disabled:cursor-wait"
          type="submit"
          aria-label={aiT.send_aria}
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-[18px] w-[18px]"
          >
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </button>
      </form>
    </div>

    <p
      class="mx-auto mt-3 flex max-w-[900px] items-start gap-[7px] font-mono text-[11px] text-[color:var(--muted)] opacity-75"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        fill="currentColor"
        class="mt-[1px] h-[12px] w-[12px] shrink-0"
      >
        <path
          fill-rule="evenodd"
          d="M15 8A7 7 0 1 1 1 8a7 7 0 0 1 14 0Zm-6 3.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM7.293 5.293a1 1 0 1 1 1.414 1.414L8 7.414V9.5a.5.5 0 0 0 1 0V8l.707-.707A2 2 0 1 0 6 6.5a.5.5 0 0 0 1 0 1 1 0 0 1 .293-.707Z"
          clip-rule="evenodd"></path>
      </svg>
      <span
        >{aiT.disclaimer}
        <a
          href="#contact"
          class="text-accent no-underline transition-opacity duration-150 hover:opacity-75"
          >{aiT.disclaimer_link}</a
        ></span
      >
    </p>
  </div>
</section>

<style is:global>
  .ai-dot {
    animation: pulse 2s ease-in-out infinite;
  }
  .ai-tab:hover {
    background: color-mix(in oklab, var(--accent) 12%, var(--bg-2));
    border-color: color-mix(in oklab, var(--accent) 40%, var(--line));
    color: var(--ink);
    transform: translateY(-1px);
  }
  .ai-conv::-webkit-scrollbar {
    width: 6px;
  }
  .ai-conv::-webkit-scrollbar-thumb {
    background: var(--line);
    border-radius: 3px;
  }
  .ai-msg {
    animation: msgIn 0.45s cubic-bezier(0.2, 0.7, 0.3, 1) both;
  }
  .ai-msg.ai-msg-user {
    grid-template-columns: 1fr 32px;
  }
  .ai-msg.ai-msg-user .ai-avatar {
    order: 2;
    background: color-mix(in oklab, var(--coral) 80%, transparent);
    color: #fff;
  }
  .ai-msg-user .ai-bubble {
    background: color-mix(in oklab, var(--coral) 12%, var(--bg-2));
    border-color: color-mix(in oklab, var(--coral) 30%, var(--line));
  }
  .ai-bubble p {
    margin: 0;
  }
  .ai-bubble p + p {
    margin-top: 0.7em;
  }
  .ai-bubble b {
    color: var(--accent);
    font-weight: 600;
  }
  .ai-bubble code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: color-mix(in oklab, var(--accent) 10%, transparent);
    color: var(--accent);
    padding: 1px 5px;
    border-radius: 4px;
  }
  .ai-thinking {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }
  .ai-thinking .d {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: bounce 1.2s infinite;
  }
  .ai-thinking .d:nth-child(2) {
    animation-delay: 0.15s;
  }
  .ai-thinking .d:nth-child(3) {
    animation-delay: 0.3s;
  }
</style>

<script>
  function initAI() {
    const root = document.querySelector<HTMLElement>('[data-ai-root]')
    // Astro ClientRouter can replay lifecycle events; this guard keeps init idempotent per mounted root.
    if (!root || root.dataset.ready === 'true') return
    root.dataset.ready = 'true'

    const form = root.querySelector<HTMLFormElement>('#aiForm')
    const input = root.querySelector<HTMLInputElement>('#aiInput')
    const conv = root.querySelector<HTMLElement>('#aiConv')
    const tabs = root.querySelectorAll<HTMLButtonElement>('.ai-tab')
    if (!form || !input || !conv) return
    const msg = JSON.parse(form.dataset.ai || '{}')

    const history: { role: string; content: string }[] = []

    function escHtml(s: string) {
      return s.replace(
        /[&<>"']/g,
        (c: string) =>
          ({
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;'
          })[c as '&'] || c
      )
    }
    function renderMd(s: string) {
      return escHtml(s)
        .replace(/\*\*([^*]+)\*\*/g, '<b>$1</b>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .split(/\n\n+/)
        .map((p: string) => `<p>${p.replace(/\n/g, '<br/>')}</p>`)
        .join('')
    }
    function addMsg(role: string, text: string) {
      const wrap = document.createElement('div')
      wrap.className =
        'ai-msg grid items-start gap-3 ' +
        (role === 'user'
          ? 'ai-msg-user grid-cols-[1fr_32px]'
          : 'ai-msg-bot grid-cols-[32px_1fr]')
      wrap.innerHTML = `<div class="ai-avatar flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent font-display text-[14px] font-bold text-[#0B0C10]">${role === 'user' ? msg.user_avatar || 'YOU' : 'L'}</div><div class="ai-bubble rounded-[14px] border border-line bg-[color:color-mix(in_oklab,var(--bg)_60%,transparent)] px-[18px] py-[14px] text-[14.5px] leading-[1.6] text-ink min-w-0 break-words">${role === 'user' ? `<p>${escHtml(text)}</p>` : renderMd(text)}</div>`
      conv.appendChild(wrap)
      conv.scrollTop = conv.scrollHeight
      return wrap
    }
    function addThinking() {
      const wrap = document.createElement('div')
      wrap.className =
        'ai-msg ai-msg-bot grid grid-cols-[32px_1fr] items-start gap-3'
      wrap.innerHTML = `<div class="ai-avatar flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent font-display text-[14px] font-bold text-[#0B0C10]">L</div><div class="ai-bubble rounded-[14px] border border-line bg-[color:color-mix(in_oklab,var(--bg)_60%,transparent)] px-[18px] py-[14px] text-[14.5px] leading-[1.6] text-ink min-w-0 break-words"><div class="ai-thinking"><span class="d"></span><span class="d"></span><span class="d"></span><span class="ml-[6px]">${msg.thinking || 'thinking...'}</span></div></div>`
      conv.appendChild(wrap)
      conv.scrollTop = conv.scrollHeight
      return wrap
    }

    async function ask(question: string) {
      if (!question.trim()) return
      root.querySelector('#aiInvite')?.remove()
      addMsg('user', question)
      history.push({ role: 'user', content: question })
      const sendBtn = form!.querySelector('.ai-send') as HTMLButtonElement
      sendBtn.disabled = true
      input!.value = ''
      const thinking = addThinking()
      try {
        const res = await fetch('/api/ask-lee', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history.slice(-6) })
        })
        thinking.remove()
        const bubble = addMsg('assistant', '')
        const bub = bubble.querySelector('.ai-bubble') as HTMLElement
        const reader = res.body!.getReader()
        const dec = new TextDecoder()
        let buf = ''
        let answer = ''
        let meta: { sources?: string[] } | null = null
        while (true) {
          const { value, done } = await reader.read()
          if (done) break
          buf += dec.decode(value, { stream: true })
          const parts = buf.split('\n\n')
          buf = parts.pop() || ''
          for (const part of parts) {
            if (!part.startsWith('data: ')) continue
            try {
              const evt = JSON.parse(part.slice(6))
              if (evt.type === 'chunk') {
                answer += evt.content
                bub.innerHTML = renderMd(answer)
              } else if (evt.type === 'done') {
                meta = evt
              } else if (evt.type === 'error') {
                answer = answer || msg.error_fallback || 'Error'
                bub.innerHTML = renderMd(answer)
              }
            } catch {
              // ignore malformed SSE lines
            }
          }
          conv!.scrollTop = conv!.scrollHeight
        }
        history.push({
          role: 'assistant',
          content: answer || msg.error_fallback || 'Error'
        })
        if (meta?.sources?.length) {
          bub.insertAdjacentHTML(
            'beforeend',
            `<div class="ai-sources mt-2 text-[12px] opacity-60">Sources: ${meta.sources.map((s: string) => `✓ ${s}`).join('  ')}</div>`
          )
        }
      } catch {
        thinking.querySelector('.ai-bubble')!.innerHTML =
          `<p>${msg.crash_fallback || 'Error'}</p>`
      } finally {
        sendBtn.disabled = false
        input!.focus()
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault()
      ask(input!.value)
    })
    tabs.forEach((t) =>
      t.addEventListener('click', () => ask(t.dataset.suggest || ''))
    )
  }
  initAI()
  document.addEventListener('astro:page-load', initAI)
</script>
