---
import { useTranslation } from 'src/i18n/utils'

interface Props { lang: 'es' | 'en' }
const { lang } = Astro.props
const t = useTranslation(lang)
const aiT = t('ai')
---

<section class="s" id="ai">
  <div class="wrap">
    <div class="s-head reveal">
      <span class="s-eyebrow">{t('home').ai_eyebrow}</span>
      <h2 class="s-title" set:html={t('home').ai_title} />
      <p class="s-sub">
        {t('home').ai_subtitle}
        <span class="ai-built font-mono text-[12px] text-[color:var(--muted)] block mt-[10px]">(construido con <code class="rounded px-[6px] py-[2px] text-[11.5px] text-accent" style="background:color-mix(in oklab, var(--accent) 12%, transparent)">Claude Haiku</code> · via API)</span>
      </p>
    </div>

    <div class="ai-shell reveal relative rounded-[18px] overflow-hidden mx-auto" style="max-width:900px;background:linear-gradient(180deg, var(--bg-2) 0%, color-mix(in oklab, var(--bg-2) 80%, var(--bg)) 100%);border:1px solid var(--line);box-shadow:0 24px 60px rgba(0,0,0,.35)">
      <div class="ai-shell-bar" aria-hidden="true"></div>
      <div class="ai-header flex justify-between items-center px-[18px] py-[14px] border-b border-line flex-wrap gap-3" style="background:color-mix(in oklab, var(--bg) 60%, transparent)">
        <div class="ai-status flex items-center gap-[10px] font-mono text-[12px]">
          <span class="ai-dot w-2 h-2 rounded-full" style="background:var(--mint);box-shadow:0 0 0 4px color-mix(in oklab, var(--mint) 25%, transparent)"></span>
          <span class="text-ink ai-label">lee-ai · v1</span>
          <span class="ai-model text-[color:var(--muted)] px-2 py-[2px] rounded-full border border-line text-[11px]" style="background:color-mix(in oklab, var(--bg) 70%, transparent)">claude-haiku-4-5</span>
        </div>
        <div class="flex flex-wrap gap-1">
          <button class="ai-tab font-mono text-[11px] px-[10px] py-[5px] rounded-[8px] bg-transparent border border-line text-ink-soft cursor-pointer" data-suggest={aiT.tabs.backend}>{aiT.tab_labels.backend}</button>
          <button class="ai-tab font-mono text-[11px] px-[10px] py-[5px] rounded-[8px] bg-transparent border border-line text-ink-soft cursor-pointer" data-suggest={aiT.tabs.ai_builder}>{aiT.tab_labels.ai_builder}</button>
          <button class="ai-tab font-mono text-[11px] px-[10px] py-[5px] rounded-[8px] bg-transparent border border-line text-ink-soft cursor-pointer" data-suggest={aiT.tabs.postgres}>{aiT.tab_labels.postgres}</button>
          <button class="ai-tab font-mono text-[11px] px-[10px] py-[5px] rounded-[8px] bg-transparent border border-line text-ink-soft cursor-pointer" data-suggest={aiT.tabs.culture}>{aiT.tab_labels.culture}</button>
        </div>
      </div>

      <div class="ai-conv px-[22px] pt-6 pb-3 flex flex-col gap-[18px] overflow-y-auto" id="aiConv" style="max-height:420px;scroll-behavior:smooth">
        <div class="ai-msg ai-msg-bot grid gap-3 items-start" style="grid-template-columns:32px 1fr">
          <div class="ai-avatar w-8 h-8 rounded-full flex items-center justify-center font-display font-bold text-[14px] shrink-0 bg-accent" style="color:#0B0C10">L</div>
          <div class="ai-bubble px-[18px] py-[14px] rounded-[14px] text-[14.5px] leading-[1.6] text-ink border border-line" style="background:color-mix(in oklab, var(--bg) 60%, transparent)">
            <p set:html={aiT.greeting} />
            <p class="ai-hint mt-2 font-mono text-[11.5px] text-[color:var(--muted)]">{aiT.hint}</p>
          </div>
        </div>
      </div>

      <form class="ai-form flex items-center px-[14px] py-3 border-t border-line" id="aiForm" style="background:color-mix(in oklab, var(--bg) 80%, transparent)" data-ai={JSON.stringify(aiT)}>
        <span class="font-mono text-accent font-bold px-[10px] text-[18px]">›</span>
        <input id="aiInput" type="text" placeholder={aiT.input_placeholder} autocomplete="off" maxlength="280" class="flex-1 border-none bg-transparent outline-none text-ink font-sans text-[15px] px-1 py-[10px]" />
        <button class="ai-send w-[38px] h-[38px] bg-accent border-none rounded-[10px] cursor-pointer flex items-center justify-center" type="submit" aria-label={aiT.send_aria} style="color:#0B0C10">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .ai-shell-bar { position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--accent), var(--coral), var(--mint), transparent); opacity: .8; }
  .ai-dot { animation: pulse 2s ease-in-out infinite; }
  .ai-tab { transition: all .2s; }
  .ai-tab:hover { background: color-mix(in oklab, var(--accent) 12%, var(--bg-2)); border-color: color-mix(in oklab, var(--accent) 40%, var(--line)); color: var(--ink); transform: translateY(-1px); }
  .ai-conv::-webkit-scrollbar { width: 6px; }
  .ai-conv::-webkit-scrollbar-thumb { background: var(--line); border-radius: 3px; }
  .ai-msg { animation: msgIn .45s cubic-bezier(.2,.7,.3,1) both; }
  .ai-msg.ai-msg-user { grid-template-columns: 1fr 32px; }
  .ai-msg.ai-msg-user .ai-avatar { order: 2; background: color-mix(in oklab, var(--coral) 80%, transparent); color: #fff; }
  .ai-msg-user .ai-bubble { background: color-mix(in oklab, var(--coral) 12%, var(--bg-2)); border-color: color-mix(in oklab, var(--coral) 30%, var(--line)); }
  .ai-bubble p { margin: 0; }
  .ai-bubble p + p { margin-top: 0.7em; }
  .ai-bubble b { color: var(--accent); font-weight: 600; }
  .ai-bubble code { font-family: var(--font-mono); font-size: 0.9em; background: color-mix(in oklab, var(--accent) 10%, transparent); color: var(--accent); padding: 1px 5px; border-radius: 4px; }
  .ai-thinking { display: flex; align-items: center; gap: 6px; font-family: var(--font-mono); font-size: 12px; color: var(--muted); }
  .ai-thinking .d { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: bounce 1.2s infinite; }
  .ai-thinking .d:nth-child(2) { animation-delay: .15s; }
  .ai-thinking .d:nth-child(3) { animation-delay: .3s; }
  #aiInput::placeholder { color: var(--muted); }
  .ai-send { transition: transform .2s, background .2s; }
  .ai-send:hover { transform: translateX(2px); background: var(--coral); color: #fff; }
  .ai-send:disabled { background: var(--bg-3); color: var(--muted); cursor: wait; transform: none; }
</style>

<script>
  const LEE_SYSTEM = `You are "Lee-AI", a portfolio assistant that speaks AS IF you were Lee Palacios. Be warm, concise, and direct. Match the asker's language (Spanish or English) automatically.

FACTS ABOUT LEE PALACIOS:
- Software Engineer based in Lima, Peru. 7+ years of experience.
- Currently: Senior Fullstack Engineer at Patrimore (2025—present).
- Previous: Senior Fullstack Engineer at ComunidadFeliz (Jun 2022—Aug 2024) — Ruby on Rails + React + Postgres SaaS for thousands of buildings.
- Previous: Tech Lead at Influgo (Jan 2020—May 2022) — campaign management system from scratch, Rails + React + React Native + AWS Lambda.
- Side project (paused): Inmology — AI agents for real estate automation (GPT, N8N, Python, Postgres, AWS Lambda).
- Backend at heart: loves Ruby, Python, Postgres, SQL, AWS Lambda, optimized queries.
- AI Builder: actively explores LLMs, agent orchestration with N8N, prompt engineering, Claude/GPT.
- Frontend when needed: TypeScript, React, React Native, Tailwind.
- Three cats. Will mention them charmingly when asked about personal life.
- Languages: Spanish (native), English (fluent).

STYLE RULES:
- 1-3 short paragraphs MAX.
- Be honest and concrete. Drop real examples (e.g. "una vez optimicé una query de 8s a 30ms").
- End with one short follow-up question when natural.
- Never break character.`;

  function initAI() {
    const form = document.getElementById('aiForm') as HTMLFormElement | null;
    const input = document.getElementById('aiInput') as HTMLInputElement | null;
    const conv = document.getElementById('aiConv') as HTMLElement | null;
    const tabs = document.querySelectorAll<HTMLButtonElement>('.ai-tab');
    if (!form || !input || !conv) return;
    const msg = JSON.parse(form.dataset.ai || '{}');

    const history: {role: string; content: string}[] = [];

    function escHtml(s: string) {
      return s.replace(/[&<>"']/g, (c: string) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c as '&'] || c));
    }
    function renderMd(s: string) {
      return escHtml(s)
        .replace(/\*\*([^*]+)\*\*/g, '<b>$1</b>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .split(/\n\n+/)
        .map((p: string) => `<p>${p.replace(/\n/g, '<br/>')}</p>`)
        .join('');
    }
    function addMsg(role: string, text: string) {
      const wrap = document.createElement('div');
      wrap.className = 'ai-msg grid gap-3 items-start ' + (role === 'user' ? 'ai-msg-user' : 'ai-msg-bot');
      wrap.style.gridTemplateColumns = role === 'user' ? '1fr 32px' : '32px 1fr';
      wrap.innerHTML = `<div class="ai-avatar w-8 h-8 rounded-full flex items-center justify-center font-display font-bold text-[14px] shrink-0 bg-accent" style="color:#0B0C10">${role === 'user' ? (msg.user_avatar || 'YOU') : 'L'}</div><div class="ai-bubble px-[18px] py-[14px] rounded-[14px] text-[14.5px] leading-[1.6] text-ink border border-line" style="background:color-mix(in oklab, var(--bg) 60%, transparent)">${role === 'user' ? `<p>${escHtml(text)}</p>` : renderMd(text)}</div>`;
      conv!.appendChild(wrap);
      conv!.scrollTop = conv!.scrollHeight;
      return wrap;
    }
    function addThinking() {
      const wrap = document.createElement('div');
      wrap.className = 'ai-msg ai-msg-bot grid gap-3 items-start';
      wrap.style.gridTemplateColumns = '32px 1fr';
      wrap.innerHTML = `<div class="ai-avatar w-8 h-8 rounded-full flex items-center justify-center font-display font-bold text-[14px] shrink-0 bg-accent" style="color:#0B0C10">L</div><div class="ai-bubble px-[18px] py-[14px] rounded-[14px] text-[14.5px] leading-[1.6] text-ink border border-line" style="background:color-mix(in oklab, var(--bg) 60%, transparent)"><div class="ai-thinking"><span class="d"></span><span class="d"></span><span class="d"></span><span style="margin-left:6px;">${msg.thinking || 'thinking...'}</span></div></div>`;
      conv!.appendChild(wrap);
      conv!.scrollTop = conv!.scrollHeight;
      return wrap;
    }

    async function ask(question: string) {
      if (!question.trim()) return;
      addMsg('user', question);
      history.push({ role: 'user', content: question });
      const sendBtn = form!.querySelector('.ai-send') as HTMLButtonElement;
      sendBtn.disabled = true;
      input!.value = '';
      const thinking = addThinking();
      try {
        const res = await fetch('/api/ask-lee', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history.slice(-6), system: LEE_SYSTEM })
        });
        const data = await res.json();
        thinking.remove();
        const answer = data.answer || msg.error_fallback || 'Error';
        addMsg('assistant', answer);
        history.push({ role: 'assistant', content: answer });
      } catch {
        thinking.querySelector('.ai-bubble')!.innerHTML = `<p>${msg.crash_fallback || 'Error'}</p>`;
      } finally {
        sendBtn.disabled = false;
        input!.focus();
      }
    }

    form.addEventListener('submit', (e) => { e.preventDefault(); ask(input!.value); });
    tabs.forEach(t => t.addEventListener('click', () => ask(t.dataset.suggest || '')));
  }
  initAI();
  document.addEventListener('astro:page-load', initAI);
</script>
