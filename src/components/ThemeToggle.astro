---
import Moon from 'astro-heroicons/outline/Moon.astro'
import Sun from 'astro-heroicons/outline/Sun.astro'
---

<theme-toggle>
  <button
    class="border-line bg-bg-2 hover:border-accent inline-flex h-[38px] w-[38px] cursor-pointer items-center justify-center rounded-full border transition-colors"
    aria-label="Cambiar tema"
    data-theme-toggle
    type="button"
  >
    <span class="relative h-[18px] w-[18px]">
      <span
        class="pointer-events-none absolute inset-0 transition-all duration-300 ease-out"
        data-icon="moon"
      >
        <Moon class="text-ink-soft h-[18px] w-[18px]" />
      </span>
      <span
        class="pointer-events-none absolute inset-0 transition-all duration-300 ease-out"
        data-icon="sun"
      >
        <Sun class="text-ink-soft h-[18px] w-[18px]" />
      </span>
    </span>
  </button>
</theme-toggle>

<script>
  const THEME_STORAGE_KEY = 'portfolio-theme'

  function setIconState(button: HTMLElement, theme: string) {
    const moon = button.querySelector<HTMLElement>('[data-icon="moon"]')
    const sun = button.querySelector<HTMLElement>('[data-icon="sun"]')
    const dark = theme === 'dark'

    moon?.classList.toggle('opacity-100', dark)
    moon?.classList.toggle('scale-100', dark)
    moon?.classList.toggle('rotate-0', dark)
    moon?.classList.toggle('opacity-0', !dark)
    moon?.classList.toggle('scale-75', !dark)
    moon?.classList.toggle('-rotate-45', !dark)

    sun?.classList.toggle('opacity-100', !dark)
    sun?.classList.toggle('scale-100', !dark)
    sun?.classList.toggle('rotate-0', !dark)
    sun?.classList.toggle('opacity-0', dark)
    sun?.classList.toggle('scale-75', dark)
    sun?.classList.toggle('rotate-45', dark)
  }

  function applyTheme(next: 'light' | 'dark') {
    document.documentElement.setAttribute('data-theme', next)
    localStorage.setItem(THEME_STORAGE_KEY, next)

    document.dispatchEvent(new CustomEvent('theme-changed', { detail: next }))
  }

  class ThemeToggleElement extends HTMLElement {
    private button: HTMLElement | null = null
    private onClick = () => {
      const current = document.documentElement.dataset.theme || 'dark'
      const next = current === 'dark' ? 'light' : 'dark'
      applyTheme(next)
    }

    private onThemeChanged = (event: Event) => {
      const customEvent = event as CustomEvent<'light' | 'dark'>
      const theme =
        customEvent.detail ||
        document.documentElement.dataset.theme ||
        localStorage.getItem(THEME_STORAGE_KEY) ||
        'dark'

      if (this.button) setIconState(this.button, theme)
    }

    connectedCallback() {
      this.button = this.querySelector<HTMLElement>('[data-theme-toggle]')
      if (!this.button) return

      this.button.addEventListener('click', this.onClick)
      document.addEventListener('theme-changed', this.onThemeChanged)

      const currentTheme =
        document.documentElement.dataset.theme ||
        localStorage.getItem(THEME_STORAGE_KEY) ||
        'dark'

      setIconState(this.button, currentTheme)
    }

    disconnectedCallback() {
      if (this.button) {
        this.button.removeEventListener('click', this.onClick)
      }
      document.removeEventListener('theme-changed', this.onThemeChanged)
      this.button = null
    }
  }

  if (!customElements.get('theme-toggle')) {
    customElements.define('theme-toggle', ThemeToggleElement)
  }
</script>
