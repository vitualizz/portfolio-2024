---
---

<section class="s" id="about">
  <div class="wrap">
    <div class="s-head reveal">
      <span class="s-eyebrow">// 01 · Sobre mí</span>
      <h2 class="s-title">Acerca de <span class="y">mí</span></h2>
      <p class="s-sub">El humano detrás del código — qué me mueve, qué hago, y qué tengo en la caja de herramientas.</p>
    </div>

    <div class="about-grid">
      <div class="reveal">
        <div class="about-body">
          <p>Soy un <b style="color:var(--coral);">ingeniero de software</b> peruano con <b style="color:var(--coral);">7+ años</b> entre Tech Lead y Senior Fullstack en startups LATAM. Hoy en <b>Patrimore</b>.</p>
          <p>Mi pasión es el <b style="color:var(--coral);">backend</b>: SQL afinado, arquitecturas que escalan, modelos de datos honestos. El frontend lo manejo cuando hace falta — React, React Native, Tailwind — pero donde encuentro el zen es en una query bien optimizada y una API que no rompe.</p>
          <p>En el último año he construido seriamente con <span class="g">LLMs y agentes</span> — orquestación con N8N, prompts productivos, Python como pegamento. Es la herramienta más interesante que ha aparecido en mi carrera, y todavía estoy raspando la superficie.</p>
          <p class="about-mini">
            <span class="cat-emoji">🐱</span> Vivo en Lima con tres gatos que aprueban todo mi código.
          </p>
        </div>

        <div class="stats">
          <div class="stat">
            <div class="num">7+</div>
            <div class="lbl">Años de exp.</div>
          </div>
          <div class="stat">
            <div class="num">20+</div>
            <div class="lbl">Proyectos</div>
          </div>
          <div class="stat">
            <div class="num">3</div>
            <div class="lbl">Gatos 🐱</div>
          </div>
        </div>
      </div>

      <div class="skills-block reveal">
        <div class="skill-group skill-primary">
          <h4>Backend · donde vivo</h4>
          <div class="skill-chips">
            <span class="chip chip-strong"><span class="dot"></span>Ruby on Rails</span>
            <span class="chip chip-strong"><span class="dot"></span>Postgres</span>
            <span class="chip chip-strong"><span class="dot"></span>Python</span>
            <span class="chip chip-strong"><span class="dot"></span>AWS Lambda</span>
            <span class="chip chip-strong"><span class="dot"></span>SQL</span>
          </div>
        </div>

        <div class="skill-group">
          <h4>AI Builder · explorando</h4>
          <div class="skill-chips">
            <span class="chip"><span class="dot dot-coral"></span>GPT / Claude / LLMs</span>
            <span class="chip"><span class="dot dot-coral"></span>N8N · agent orchestration</span>
            <span class="chip"><span class="dot dot-coral"></span>Prompt engineering</span>
          </div>
        </div>

        <div class="skill-group">
          <h4>Frontend · cuando hace falta</h4>
          <div class="skill-chips">
            <span class="chip"><span class="dot dot-mint"></span>TypeScript</span>
            <span class="chip"><span class="dot dot-mint"></span>React</span>
            <span class="chip"><span class="dot dot-mint"></span>React Native</span>
            <span class="chip"><span class="dot dot-mint"></span>Tailwind</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(40px,6vw,96px); align-items: start; }
  .about-body { font-size: clamp(16px,1.25vw,18px); line-height: 1.75; color: var(--ink-soft); }
  .about-body p + p { margin-top: 1.1em; }

  .stats { display: grid; grid-template-columns: repeat(3,1fr); margin-top: 36px; border: 1px solid var(--line); border-radius: 18px; overflow: hidden; background: color-mix(in oklab, var(--bg-2) 80%, transparent); }
  .stat { padding: 22px 18px; text-align: center; border-right: 1px solid var(--line); }
  .stat:last-child { border-right: none; }
  .stat .num { font-family: var(--font-display); font-size: 32px; font-weight: 700; color: var(--accent); letter-spacing: -0.02em; line-height: 1; }
  .stat .lbl { margin-top: 6px; font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; font-family: var(--font-mono); }

  .skills-block { display: flex; flex-direction: column; gap: 28px; }
  .skill-group h4 { font-family: var(--font-display); font-size: 18px; font-weight: 600; margin-bottom: 14px; color: var(--ink); display: inline-flex; align-items: baseline; gap: 8px; }
  .skill-group h4::before { content: "#"; color: var(--accent); font-weight: 700; }
  .skill-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip { display: inline-flex; align-items: center; gap: 8px; padding: 8px 14px; background: var(--bg-2); border: 1px solid var(--line); border-radius: 12px; font-size: 14px; font-weight: 500; color: var(--ink-soft); transition: transform .2s, border-color .2s, color .2s; }
  .chip:hover { transform: translateY(-2px); border-color: var(--accent); color: var(--ink); }
  .chip .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
  .chip .dot.dot-coral { background: var(--coral); }
  .chip .dot.dot-mint { background: var(--mint); }
  .chip.chip-strong { background: linear-gradient(135deg, color-mix(in oklab, var(--accent) 18%, var(--bg-2)), var(--bg-2)); border-color: color-mix(in oklab, var(--accent) 35%, var(--line)); color: var(--ink); font-weight: 600; }
  .chip.chip-strong:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 8px 16px color-mix(in oklab, var(--accent) 18%, transparent); }
  .skill-primary h4 { font-size: 20px; color: var(--ink); }

  .about-mini { font-size: 14px; color: var(--muted); margin-top: 1.6em; padding-top: 1.1em; border-top: 1px dashed var(--line); display: flex; align-items: center; gap: 8px; }
  .cat-emoji { display: inline-block; animation: catBob 3s ease-in-out infinite; transform-origin: bottom center; }

  @media (max-width: 820px) { .about-grid { grid-template-columns: 1fr; } }
</style>

<script>
  function initAbout() {
    // Animated counters
    const stats = document.querySelectorAll<HTMLElement>('.stat .num');
    const counterObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting || (e.target as HTMLElement).dataset.done) return;
        const el = e.target as HTMLElement;
        const raw = (el.textContent || '').trim();
        const m = raw.match(/^(\d+)(.*)$/);
        if (!m) return;
        const target = parseInt(m[1], 10);
        const suffix = m[2] || '';
        el.dataset.done = '1';
        const dur = 1400;
        const start = performance.now();
        function step(now: number) {
          const t = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = Math.round(target * eased) + suffix;
          if (t < 1) requestAnimationFrame(step);
          else el.textContent = target + suffix;
        }
        requestAnimationFrame(step);
      });
    }, { threshold: 0.4 });
    stats.forEach(s => counterObs.observe(s));

    // Chip stagger
    const groups = document.querySelectorAll<HTMLElement>('.skill-chips');
    const chipObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        [...(e.target as HTMLElement).children].forEach((c, i) => {
          (c as HTMLElement).style.transitionDelay = (i * 40) + 'ms';
          c.classList.add('chip-in');
        });
        chipObs.unobserve(e.target);
      });
    }, { threshold: 0.3 });
    groups.forEach(g => {
      [...g.children].forEach(c => c.classList.add('chip-prep'));
      chipObs.observe(g);
    });
  }
  initAbout();
  document.addEventListener('astro:page-load', initAbout);
</script>
