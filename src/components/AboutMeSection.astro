---
import { skillGroups } from 'src/data/skills.ts'
---

<section class="s" id="about">
  <div class="wrap">
    <div class="s-head reveal">
      <span class="s-eyebrow">// 01 · Sobre mí</span>
      <h2 class="s-title">Acerca de <span class="y">mí</span></h2>
      <p class="s-sub">El humano detrás del código — qué me mueve, qué hago, y qué tengo en la caja de herramientas.</p>
    </div>

    <div class="about-grid">
      <div class="reveal">
        <div class="about-body text-ink-soft" style="font-size:clamp(16px,1.25vw,18px);line-height:1.75">
          <p>Soy un <b class="text-coral">ingeniero de software</b> peruano con <b class="text-coral">7+ años</b> entre Tech Lead y Senior Fullstack en startups LATAM. Hoy en <b>Patrimore</b>.</p>
          <p>Mi pasión es el <b class="text-coral">backend</b>: SQL afinado, arquitecturas que escalan, modelos de datos honestos. El frontend lo manejo cuando hace falta — React, React Native, Tailwind — pero donde encuentro el zen es en una query bien optimizada y una API que no rompe.</p>
          <p>En el último año he construido seriamente con <span class="g">LLMs y agentes</span> — orquestación con N8N, prompts productivos, Python como pegamento. Es la herramienta más interesante que ha aparecido en mi carrera, y todavía estoy raspando la superficie.</p>
          <p class="about-mini text-muted-custom text-[14px] mt-[1.6em] pt-[1.1em] flex items-center gap-2" style="border-top:1px dashed var(--line)">
            <span class="cat-emoji inline-block" style="transform-origin:bottom center">🐱</span> Vivo en Lima con tres gatos que aprueban todo mi código.
          </p>
        </div>

        <div class="stats border border-line grid mt-9 rounded-[18px] overflow-hidden" style="grid-template-columns:repeat(3,1fr);background:color-mix(in oklab, var(--bg-2) 80%, transparent)">
          <div class="stat border-r border-line px-[18px] py-[22px] text-center">
            <div class="num text-accent font-display text-[32px] font-bold tracking-[-0.02em] leading-none">7+</div>
            <div class="lbl text-muted-custom mt-[6px] text-[12px] uppercase tracking-[0.05em] font-mono">Años de exp.</div>
          </div>
          <div class="stat border-r border-line px-[18px] py-[22px] text-center">
            <div class="num text-accent font-display text-[32px] font-bold tracking-[-0.02em] leading-none">20+</div>
            <div class="lbl text-muted-custom mt-[6px] text-[12px] uppercase tracking-[0.05em] font-mono">Proyectos</div>
          </div>
          <div class="stat px-[18px] py-[22px] text-center">
            <div class="num text-accent font-display text-[32px] font-bold tracking-[-0.02em] leading-none">3</div>
            <div class="lbl text-muted-custom mt-[6px] text-[12px] uppercase tracking-[0.05em] font-mono">Gatos 🐱</div>
          </div>
        </div>
      </div>

      <div class="skills-block flex flex-col gap-7 reveal">
        {skillGroups.map(group => (
          <div class={`skill-group${group.primary ? ' skill-primary' : ''}`}>
            <h4 class={`text-ink font-display font-semibold mb-[14px] inline-flex items-baseline gap-2${group.primary ? ' text-[20px]' : ' text-[18px]'}`}>{group.label}</h4>
            <div class="skill-chips flex flex-wrap gap-2">
              {group.items.map(item => (
                <span class={`chip bg-bg-2 border border-line text-ink-soft inline-flex items-center gap-2 px-[14px] py-2 rounded-[12px] text-[14px] font-medium transition-transform transition-colors duration-200${group.chipVariant === 'strong' ? ' chip-strong' : ''}`}>
                  <span class={`dot w-2 h-2 rounded-full${group.dotColor === 'coral' ? ' bg-coral' : group.dotColor === 'mint' ? ' bg-mint' : ' bg-accent'}`}></span>
                  {item.label}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: clamp(40px,6vw,96px); align-items: start; }
  .about-body p + p { margin-top: 1.1em; }

  .skill-group h4::before { content: "#"; color: var(--accent); font-weight: 700; }
  .chip:hover { transform: translateY(-2px); border-color: var(--accent); color: var(--ink); }
  .chip.chip-strong { background: linear-gradient(135deg, color-mix(in oklab, var(--accent) 18%, var(--bg-2)), var(--bg-2)); border-color: color-mix(in oklab, var(--accent) 35%, var(--line)); color: var(--ink); font-weight: 600; }
  .chip.chip-strong:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 8px 16px color-mix(in oklab, var(--accent) 18%, transparent); }

  .cat-emoji { animation: catBob 3s ease-in-out infinite; }

  @media (max-width: 820px) { .about-grid { grid-template-columns: 1fr; } }
</style>

<script>
  function initAbout() {
    // Animated counters
    const stats = document.querySelectorAll<HTMLElement>('.stat .num');
    const counterObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting || (e.target as HTMLElement).dataset.done) return;
        const el = e.target as HTMLElement;
        const raw = (el.textContent || '').trim();
        const m = raw.match(/^(\d+)(.*)$/);
        if (!m) return;
        const target = parseInt(m[1], 10);
        const suffix = m[2] || '';
        el.dataset.done = '1';
        const dur = 1400;
        const start = performance.now();
        function step(now: number) {
          const t = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = Math.round(target * eased) + suffix;
          if (t < 1) requestAnimationFrame(step);
          else el.textContent = target + suffix;
        }
        requestAnimationFrame(step);
      });
    }, { threshold: 0.4 });
    stats.forEach(s => counterObs.observe(s));

    // Chip stagger
    const groups = document.querySelectorAll<HTMLElement>('.skill-chips');
    const chipObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        [...(e.target as HTMLElement).children].forEach((c, i) => {
          (c as HTMLElement).style.transitionDelay = (i * 40) + 'ms';
          c.classList.add('chip-in');
        });
        chipObs.unobserve(e.target);
      });
    }, { threshold: 0.3 });
    groups.forEach(g => {
      [...g.children].forEach(c => c.classList.add('chip-prep'));
      chipObs.observe(g);
    });
  }
  initAbout();
  document.addEventListener('astro:page-load', initAbout);
</script>
