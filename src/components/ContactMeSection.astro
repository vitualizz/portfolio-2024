---
import Envelope from 'astro-heroicons/outline/Envelope.astro'
import DocumentText from 'astro-heroicons/outline/DocumentText.astro'
import GithubIcon from '../components/icons/Github.astro'
import Linkedin from '../components/icons/Linkedin.astro'
import { getLangFromUrl, useTranslation } from '../i18n/utils.ts'

const lang = getLangFromUrl(Astro.url)
const t = useTranslation(lang)

const tContactMe = t('contact_me')
const tForm = tContactMe.form
---

<section
  data-section="contact_me"
  id="contact_me"
  class="bg-bg px-6 lg:px-16 py-32"
>
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row lg:justify-around xl:justify-between gap-16">
    <div class="w-full lg:w-5/12 text-center lg:text-left">
      <h3
        class="font-display text-4xl font-bold md:text-5xl mb-12"
        set:html={tContactMe.tell_me}
      />

      <a href="mailto:vitualizz@gmail.com">
        <div class="mt-5 flex items-center gap-4 rounded-lg bg-surface border border-border px-7 py-3 transition hover:bg-surface-2">
          <Envelope class="h-8 w-8 shrink-0" />
          <p class="font-medium">vitualizz@gmail.com</p>
        </div>
      </a>
      <a href="https://github.com/vitualizz" target="_blank" rel="noopener noreferrer">
        <div class="mt-4 flex items-center gap-4 rounded-lg bg-surface border border-border px-7 py-3 transition hover:bg-surface-2">
          <GithubIcon class="h-8 w-8 shrink-0" />
          <p class="font-medium">vitualizz</p>
        </div>
      </a>
      <a href="https://www.linkedin.com/in/vitualizz/" target="_blank" rel="noopener noreferrer">
        <div class="mt-4 flex items-center gap-4 rounded-lg bg-surface border border-border px-7 py-3 transition hover:bg-surface-2">
          <Linkedin class="h-8 w-8 shrink-0" />
          <p class="font-medium">Lee Palacios</p>
        </div>
      </a>
      <a
        href={`/cv/${lang}.pdf`}
        download={`LeePalacios_${lang}.pdf`}
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="mt-4 flex items-center gap-4 rounded-lg bg-surface border border-border px-7 py-3 transition hover:bg-surface-2">
          <DocumentText class="h-8 w-8 shrink-0" />
          <p class="font-medium">{tContactMe.resume_label}</p>
        </div>
      </a>
    </div>

    <div class="w-full max-w-sm shrink-0 bg-surface-2 border border-border rounded-xl">
      <form
        id="contactForm"
        action="/api/contact"
        method="POST"
        class="p-8"
        data-i18n-submitting={tForm.submitting}
        data-i18n-success={tForm.success}
        data-i18n-error={tForm.error}
      >
        <h3 class="font-display text-xl font-bold md:text-2xl mb-6" set:html={tContactMe.send_message_me} />

        <div class="form-control mb-4">
          <label class="label pb-1">
            <span class="label-text font-medium">{tForm.name_label}</span>
          </label>
          <input
            type="text"
            placeholder={tForm.name_placeholder}
            class="input input-bordered w-full"
            name="name"
            required
          />
        </div>

        <div class="form-control mb-4">
          <label class="label pb-1">
            <span class="label-text font-medium">{tForm.email_label}</span>
          </label>
          <input
            type="email"
            placeholder={tForm.email_placeholder}
            class="input input-bordered w-full"
            name="email"
            required
          />
        </div>

        <div class="form-control mb-6">
          <label class="label pb-1">
            <span class="label-text font-medium">{tForm.message_label}</span>
          </label>
          <textarea
            placeholder={tForm.message_placeholder}
            class="textarea input-bordered min-h-28 w-full"
            name="description"
            required></textarea>
        </div>

        <div class="form-control">
          <button type="submit" class="btn btn-primary w-full">{tForm.submit}</button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  document
    .getElementById('contactForm')
    ?.addEventListener('submit', async function (e) {
      e.preventDefault()

      const form = this as HTMLFormElement
      const button = form.querySelector('button[type="submit"]') as HTMLButtonElement
      const originalText = button.innerHTML

      const submittingText = form.dataset.i18nSubmitting ?? 'Sending...'
      const successText = form.dataset.i18nSuccess ?? 'Message sent!'
      const errorText = form.dataset.i18nError ?? 'Failed to send.'

      // Sending animation
      button.innerHTML = `
        <svg class="animate-spin w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="m4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        ${submittingText}
      `

      const formData = new FormData(form)

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData
        })

        if (response.ok) {
          button.innerHTML = `
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
            </svg>
            ${successText}
          `
          form.reset()
        } else {
          throw new Error('send failed')
        }
      } catch (err) {
        button.innerHTML = `
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-5v2H9v-2h2zm0-8v6H9V5h2z" clip-rule="evenodd"></path>
          </svg>
          ${errorText}
        `
      }

      // Restore after 3 seconds
      setTimeout(() => {
        button.innerHTML = originalText
      }, 3000)
    })
</script>
