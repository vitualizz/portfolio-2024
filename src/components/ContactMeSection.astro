---
---

<!-- Contact section -->
<section class="s" id="contact">
  <div class="wrap">
    <div class="contact-card reveal">
      <h2 class="contact-title">Hablemos<br/>Cuéntame sobre tu <em>Proyecto</em> ✨</h2>
      <p class="contact-sub">Si tienes una idea que necesita manos expertas — código limpio, escalable y enviado a tiempo — me encantaría escucharte. Respondo en menos de 24 horas hábiles.</p>
      <div class="contact-actions">
        <button class="btn-primary" id="openContactModal">Enviar mensaje <span>✉</span></button>
        <a class="btn-ghost" href="/cv/es.pdf">Descargar CV <span>↓</span></a>
      </div>
    </div>
  </div>
</section>

<!-- Contact modal -->
<dialog class="modal" id="contactModal" aria-labelledby="contactTitle">
  <div class="modal-panel">
    <button class="modal-close" id="closeContactModal" aria-label="Cerrar">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
    </button>
    <div class="modal-eyebrow">// Hablemos</div>
    <h3 id="contactTitle">Cuéntame sobre tu proyecto</h3>
    <p class="modal-sub">Respondo en menos de 24 horas hábiles. Para algo urgente, ping también por LinkedIn.</p>

    <form class="contact-form" id="contactForm" action="/api/contact" method="POST" novalidate>
      <div class="field">
        <label for="cf-name">Tu nombre</label>
        <input id="cf-name" type="text" name="name" required placeholder="ej. Ana Pérez" />
      </div>
      <div class="field">
        <label for="cf-email">Email</label>
        <input id="cf-email" type="email" name="email" required placeholder="tu@email.com" />
      </div>
      <div class="field">
        <label for="cf-message">Mensaje</label>
        <textarea id="cf-message" name="description" required placeholder="Cuéntame qué necesitas, qué stack tienes, plazos..."></textarea>
      </div>
      <div class="field">
        <button type="submit" class="form-submit">
          Enviar mensaje
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
    </form>

    <div class="form-success" id="contactSuccess" hidden>
      <div class="check">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h4>¡Mensaje enviado!</h4>
      <p>Te contesto en menos de 24h hábiles.</p>
    </div>
  </div>
</dialog>

<style>
  .contact-card { max-width: 920px; margin: 0 auto; background: linear-gradient(160deg, color-mix(in oklab, var(--accent) 12%, var(--bg-2)), var(--bg-2)); border: 1px solid color-mix(in oklab, var(--accent) 30%, var(--line)); border-radius: 28px; padding: clamp(40px,6vw,80px); text-align: center; position: relative; overflow: hidden; }
  .contact-card::before { content: ""; position: absolute; top: -60%; left: 50%; transform: translateX(-50%); width: 600px; height: 600px; background: radial-gradient(circle, color-mix(in oklab, var(--accent) 30%, transparent), transparent 70%); pointer-events: none; filter: blur(20px); }
  .contact-title { font-size: clamp(36px,5.5vw,64px); font-weight: 700; letter-spacing: -0.03em; line-height: 1.02; margin: 0 0 16px; position: relative; }
  .contact-title em { font-style: normal; color: var(--accent); }
  .contact-sub { color: var(--ink-soft); font-size: 17px; max-width: 52ch; margin: 0 auto 32px; line-height: 1.6; position: relative; }
  .contact-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; position: relative; }
  .btn-primary { display: inline-flex; align-items: center; gap: 10px; padding: 14px 26px; background: var(--accent); color: #0B0C10; border-radius: 999px; font-size: 15px; font-weight: 600; transition: transform .2s, box-shadow .2s; border: none; cursor: pointer; font-family: inherit; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 32px color-mix(in oklab, var(--accent) 40%, transparent); }
  .btn-ghost { display: inline-flex; align-items: center; gap: 10px; padding: 14px 26px; border: 1px solid var(--line); color: var(--ink); border-radius: 999px; font-size: 15px; font-weight: 500; background: color-mix(in oklab, var(--bg) 50%, transparent); transition: border-color .2s, transform .2s; }
  .btn-ghost:hover { border-color: var(--accent); transform: translateY(-2px); }
</style>

<script>
  function initContact() {
    const modal = document.getElementById('contactModal') as HTMLDialogElement | null;
    const openBtn = document.getElementById('openContactModal');
    const closeBtn = document.getElementById('closeContactModal');
    const form = document.getElementById('contactForm') as HTMLFormElement | null;
    const success = document.getElementById('contactSuccess');

    // Also wire up any [data-open-modal="contact"] buttons (from hero)
    document.querySelectorAll('[data-open-modal="contact"]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        modal?.showModal();
        document.body.style.overflow = 'hidden';
      });
    });

    if (openBtn && modal) {
      openBtn.addEventListener('click', () => { modal.showModal(); document.body.style.overflow = 'hidden'; });
    }
    if (closeBtn && modal) {
      closeBtn.addEventListener('click', () => { modal.close(); document.body.style.overflow = ''; });
      modal.addEventListener('click', (e) => {
        const r = modal.getBoundingClientRect();
        const inside = e.clientX >= r.left && e.clientX <= r.right && e.clientY >= r.top && e.clientY <= r.bottom;
        if (!inside) { modal.close(); document.body.style.overflow = ''; }
      });
      modal.addEventListener('close', () => { document.body.style.overflow = ''; });
    }

    if (form && success) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('.form-submit') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Enviando...';
        const formData = new FormData(form);
        try {
          const res = await fetch('/api/contact', { method: 'POST', body: formData });
          if (res.ok) {
            form.hidden = true;
            success.hidden = false;
            setTimeout(() => {
              form.reset(); form.hidden = false; success.hidden = true;
              btn.disabled = false;
              btn.textContent = 'Enviar mensaje';
            }, 6000);
          } else throw new Error('failed');
        } catch {
          btn.disabled = false;
          btn.textContent = 'Error — intenta de nuevo';
          setTimeout(() => { btn.textContent = 'Enviar mensaje'; }, 3000);
        }
      });
    }
  }
  initContact();
  document.addEventListener('astro:page-load', initContact);
</script>
