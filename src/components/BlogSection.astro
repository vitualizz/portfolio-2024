---
interface Props {
  posts: any[]
  lang: 'es' | 'en'
}
const { posts, lang } = Astro.props
---

<section class="s" id="blog">
  <div class="wrap">
    <div class="s-head reveal">
      <span class="s-eyebrow">// 05 · Notas</span>
      <h2 class="s-title">Lo que <span class="y">escribo</span></h2>
      <p class="s-sub">Notas técnicas sobre lo que voy aprendiendo.</p>
    </div>

    <div class="blog-grid grid gap-5" style="grid-template-columns:repeat(3,1fr)">
      {posts.map(post => {
        const slug = post.slug.split('/')[0]
        const date = post.data.date.toLocaleDateString('es-PE', { day: 'numeric', month: 'short', year: 'numeric' })
        return (
          <a class="blog-card bg-bg-2 border border-line text-ink text-left rounded-[18px] px-[26px] pt-[26px] pb-[22px] cursor-pointer flex flex-col relative overflow-hidden reveal" href={`/${lang}/blog/${slug}`} style="transition:transform .35s cubic-bezier(.2,.7,.3,1), border-color .3s, box-shadow .3s">
            <div class="flex gap-3 items-center font-mono text-[11px] text-muted-custom uppercase tracking-[0.04em] mb-4" style="letter-spacing:0.04em">
              <span class="blog-tag text-accent py-[2px] px-2 rounded-full" style="border:1px solid color-mix(in oklab, var(--accent) 35%, var(--line));background:color-mix(in oklab, var(--accent) 8%, transparent)">{post.data.tags[0]}</span>
              <span class="text-muted-custom">{date}</span>
            </div>
            <h3 class="text-[22px] font-bold tracking-[-0.02em] mb-[10px] leading-[1.15]">{post.data.title}</h3>
            <p class="text-muted-custom text-[14.5px] leading-[1.6] mb-[18px] flex-1">{post.data.shortDescription}</p>
            <div class="blog-foot text-accent flex justify-between items-center font-mono text-[12px]">
              <span>Leer artículo</span>
              <span class="arrow transition-transform duration-[250ms]">↗</span>
            </div>
          </a>
        )
      })}
    </div>
  </div>
</section>

<style>
  @media (max-width: 920px) { .blog-grid { grid-template-columns: 1fr !important; } }
  .blog-card::before { content: ""; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--accent); transform: scaleX(0); transform-origin: left; transition: transform .4s ease; }
  .blog-card:hover::before { transform: scaleX(1); }
  .blog-card:hover { transform: translateY(-6px); border-color: color-mix(in oklab, var(--accent) 40%, var(--line)); box-shadow: 0 24px 40px rgba(0,0,0,.3); }
  .blog-card:hover .blog-foot .arrow { transform: translate(4px,-4px); }
</style>
